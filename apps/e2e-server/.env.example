# ═══════════════════════════════════════════════════════════
# E2E Key Server — Environment Variables
# Copy to .env and fill in values
# ═══════════════════════════════════════════════════════════

# ── Database (Neon PostgreSQL) ───────────────────────────
DATABASE_URL=postgres://user:pass@localhost:5432/mizanly_e2e?sslmode=disable

# ── Auth (Clerk — for JWT verification) ──────────────────
CLERK_SECRET_KEY=sk_test_...

# ── Cache & Rate Limiting (Redis) ────────────────────────
REDIS_URL=redis://localhost:6379

# ── Server ───────────────────────────────────────────────
PORT=8080
NODE_ENV=development

# ── Inter-service (NestJS → E2E callbacks) ───────────────
NESTJS_INTERNAL_URL=http://localhost:3000
INTERNAL_WEBHOOK_SECRET=generate-a-random-secret-here

# ── Transparency (Ed25519 signing key for Merkle root) ───
TRANSPARENCY_SIGNING_KEY=

# ── Monitoring ───────────────────────────────────────────
SENTRY_DSN=
