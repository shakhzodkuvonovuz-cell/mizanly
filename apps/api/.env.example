# ═══════════════════════════════════════════════════════════
# Mizanly API — Environment Variables Template
# Copy to .env and fill in values
# ═══════════════════════════════════════════════════════════

# ── 1. DATABASE (Neon PostgreSQL) ─────────────────────────
DATABASE_URL="postgresql://user:password@host:5432/mizanly?sslmode=require&connection_limit=10"
DIRECT_DATABASE_URL="postgresql://user:password@host:5432/mizanly?sslmode=require"

# ── 2. AUTH (Clerk) ───────────────────────────────────────
CLERK_SECRET_KEY="sk_test_..."
CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_WEBHOOK_SECRET="whsec_..."

# ── 3. CACHE & QUEUES (Upstash Redis) ────────────────────
REDIS_URL="rediss://default:password@host:6379"

# ── 4. PAYMENTS (Stripe) ─────────────────────────────────
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# ── 5. AI SERVICES ────────────────────────────────────────
ANTHROPIC_API_KEY="sk-ant-..."
OPENAI_API_KEY="sk-..."
GEMINI_API_KEY="AI..."

# ── 6. FILE STORAGE (Cloudflare R2) ──────────────────────
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="mizanly-media"
R2_PUBLIC_URL="https://pub-xxx.r2.dev"

# ── 6b. CLOUDFLARE IMAGE RESIZING ────────────────────────
CF_IMAGE_RESIZING_ENABLED=false

# ── 7. VIDEO HOSTING (Cloudflare Stream) ─────────────────
CF_STREAM_ACCOUNT_ID=""
CF_STREAM_API_TOKEN=""
CF_STREAM_WEBHOOK_SECRET=""

# ── 8. SEARCH (Meilisearch) ──────────────────────────────
MEILISEARCH_HOST="http://localhost:7700"
MEILISEARCH_API_KEY=""

# ── 9. EMAIL (Resend) ────────────────────────────────────
RESEND_API_KEY="re_..."

# ── 10. ERROR MONITORING (Sentry) ────────────────────────
SENTRY_DSN="https://xxx@sentry.io/xxx"

# ── 11. INTER-SERVICE COMMUNICATION (Go ↔ NestJS) ────────
INTERNAL_SERVICE_KEY="generate-a-random-secret-here"
INTERNAL_WEBHOOK_SECRET="generate-a-random-secret-here"
NESTJS_INTERNAL_URL="http://localhost:3000"
NESTJS_BASE_URL="http://localhost:3000"

# ── 12. SECURITY ─────────────────────────────────────────
TOTP_ENCRYPTION_KEY=""
TRANSPARENCY_SIGNING_KEY=""

# ── 13. ISLAMIC DATA ─────────────────────────────────────
GOLD_PRICE_PER_GRAM="92"
SILVER_PRICE_PER_GRAM="1.05"

# ── 14. PUSH NOTIFICATIONS (Expo) ───────────────────────
EXPO_ACCESS_TOKEN=""

# ── 15. APP CONFIG ───────────────────────────────────────
NODE_ENV="development"
PORT=3000
APP_URL="http://localhost:3000"
API_URL="http://localhost:3000"
CORS_ORIGINS="http://localhost:8081,http://localhost:8082"
