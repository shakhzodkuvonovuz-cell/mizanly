{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "installCommand": "NODE_ENV=development npm install",
    "buildCommand": "npx prisma generate && rm -rf dist && npx nest build && ls dist/main.js"
  },
  "deploy": {
    "startCommand": "node -r tsconfig-paths/register dist/main.js",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
