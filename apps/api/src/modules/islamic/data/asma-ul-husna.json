[
  { "number": 1, "arabicName": "الرَّحْمَنُ", "transliteration": "Ar-Rahman", "englishMeaning": "The Most Gracious", "explanation": "The One who has plenty of mercy for the believers and the blasphemers in this world and especially for the believers in the hereafter.", "quranRef": "1:1" },
  { "number": 2, "arabicName": "الرَّحِيمُ", "transliteration": "Ar-Raheem", "englishMeaning": "The Most Merciful", "explanation": "The One who has plenty of mercy for the believers.", "quranRef": "1:1" },
  { "number": 3, "arabicName": "المَلِكُ", "transliteration": "Al-Malik", "englishMeaning": "The King", "explanation": "The One with the complete dominion, the One whose dominion is clear from imperfection.", "quranRef": "59:23" },
  { "number": 4, "arabicName": "القُدُّوسُ", "transliteration": "Al-Quddus", "englishMeaning": "The Most Sacred", "explanation": "The One who is pure from any imperfection and clear from children and adversaries.", "quranRef": "59:23" },
  { "number": 5, "arabicName": "السَّلاَمُ", "transliteration": "As-Salam", "englishMeaning": "The Source of Peace", "explanation": "The One who is free from every imperfection.", "quranRef": "59:23" },
  { "number": 6, "arabicName": "المُؤْمِنُ", "transliteration": "Al-Mu'min", "englishMeaning": "The Guardian of Faith", "explanation": "The One who witnessed for Himself that no one is God but Him. And He witnessed for His believers that they are truthful.", "quranRef": "59:23" },
  { "number": 7, "arabicName": "المُهَيْمِنُ", "transliteration": "Al-Muhaymin", "englishMeaning": "The Protector", "explanation": "The One who witnesses the saying and deeds of His creatures.", "quranRef": "59:23" },
  { "number": 8, "arabicName": "العَزِيزُ", "transliteration": "Al-Aziz", "englishMeaning": "The Almighty", "explanation": "The Defeater who is never defeated.", "quranRef": "59:23" },
  { "number": 9, "arabicName": "الجَبَّارُ", "transliteration": "Al-Jabbar", "englishMeaning": "The Compeller", "explanation": "The One that nothing happens in His dominion except that which He willed.", "quranRef": "59:23" },
  { "number": 10, "arabicName": "المُتَكَبِّرُ", "transliteration": "Al-Mutakabbir", "englishMeaning": "The Supreme", "explanation": "The One who is clear from the attributes of the creatures and from resembling them.", "quranRef": "59:23" },
  { "number": 11, "arabicName": "الخَالِقُ", "transliteration": "Al-Khaliq", "englishMeaning": "The Creator", "explanation": "The One who brings everything from non-existence to existence.", "quranRef": "59:24" },
  { "number": 12, "arabicName": "البَارِئُ", "transliteration": "Al-Bari", "englishMeaning": "The Maker", "explanation": "The Creator who has the power to turn the entities.", "quranRef": "59:24" },
  { "number": 13, "arabicName": "المُصَوِّرُ", "transliteration": "Al-Musawwir", "englishMeaning": "The Fashioner", "explanation": "The One who forms His creatures in different pictures.", "quranRef": "59:24" },
  { "number": 14, "arabicName": "الغَفَّارُ", "transliteration": "Al-Ghaffar", "englishMeaning": "The Great Forgiver", "explanation": "The One who forgives the sins of His servants time and time again.", "quranRef": "20:82" },
  { "number": 15, "arabicName": "القَهَّارُ", "transliteration": "Al-Qahhar", "englishMeaning": "The All-Prevailing One", "explanation": "The Dominant One who prevails over all creation.", "quranRef": "13:16" },
  { "number": 16, "arabicName": "الوَهَّابُ", "transliteration": "Al-Wahhab", "englishMeaning": "The Supreme Bestower", "explanation": "The One who gives freely without expecting any return.", "quranRef": "3:8" },
  { "number": 17, "arabicName": "الرَّزَّاقُ", "transliteration": "Ar-Razzaq", "englishMeaning": "The Provider", "explanation": "The One who provides sustenance to all His creation.", "quranRef": "51:58" },
  { "number": 18, "arabicName": "الفَتَّاحُ", "transliteration": "Al-Fattah", "englishMeaning": "The Supreme Solver", "explanation": "The One who opens for His servants the closed worldly and religious matters.", "quranRef": "34:26" },
  { "number": 19, "arabicName": "العَلِيمُ", "transliteration": "Al-Aleem", "englishMeaning": "The All-Knowing", "explanation": "The One nothing is absent from His knowledge.", "quranRef": "2:29" },
  { "number": 20, "arabicName": "القَابِضُ", "transliteration": "Al-Qabid", "englishMeaning": "The Withholder", "explanation": "The One who constricts the sustenance by His wisdom." },
  { "number": 21, "arabicName": "البَاسِطُ", "transliteration": "Al-Basit", "englishMeaning": "The Expander", "explanation": "The One who constricts and expands the sustenance." },
  { "number": 22, "arabicName": "الخَافِضُ", "transliteration": "Al-Khafid", "englishMeaning": "The Reducer", "explanation": "The One who lowers whoever He willed by His destruction." },
  { "number": 23, "arabicName": "الرَّافِعُ", "transliteration": "Ar-Rafi", "englishMeaning": "The Exalter", "explanation": "The One who raises whoever He willed by His endowment.", "quranRef": "58:11" },
  { "number": 24, "arabicName": "المُعِزُّ", "transliteration": "Al-Mu'izz", "englishMeaning": "The Bestower of Honors", "explanation": "He gives esteem to whoever He willed, hence there is no one to degrade him." },
  { "number": 25, "arabicName": "المُذِلُّ", "transliteration": "Al-Mudhill", "englishMeaning": "The Humiliator", "explanation": "He degrades whoever He willed, hence there is no one to honor him." },
  { "number": 26, "arabicName": "السَّمِيعُ", "transliteration": "As-Sami", "englishMeaning": "The All-Hearing", "explanation": "The One who hears all things that are heard by His eternal hearing without an ear.", "quranRef": "2:127" },
  { "number": 27, "arabicName": "البَصِيرُ", "transliteration": "Al-Basir", "englishMeaning": "The All-Seeing", "explanation": "The One who sees all things that are seen by His eternal seeing without a pupil.", "quranRef": "17:1" },
  { "number": 28, "arabicName": "الحَكَمُ", "transliteration": "Al-Hakam", "englishMeaning": "The Impartial Judge", "explanation": "He is the Ruler and His judgment is His Word." },
  { "number": 29, "arabicName": "العَدْلُ", "transliteration": "Al-Adl", "englishMeaning": "The Utterly Just", "explanation": "The One who is entitled to do what He does." },
  { "number": 30, "arabicName": "اللَّطِيفُ", "transliteration": "Al-Latif", "englishMeaning": "The Subtle One", "explanation": "The One who is kind to His servants and endows upon them.", "quranRef": "6:103" },
  { "number": 31, "arabicName": "الخَبِيرُ", "transliteration": "Al-Khabir", "englishMeaning": "The All-Aware", "explanation": "The One who knows the truth of things.", "quranRef": "6:18" },
  { "number": 32, "arabicName": "الحَلِيمُ", "transliteration": "Al-Halim", "englishMeaning": "The Forbearing", "explanation": "The One who delays the punishment for those who deserve it." },
  { "number": 33, "arabicName": "العَظِيمُ", "transliteration": "Al-Azim", "englishMeaning": "The Magnificent", "explanation": "The One deserving the attributes of Exaltment, Glory, Extolment, and Purity.", "quranRef": "2:255" },
  { "number": 34, "arabicName": "الغَفُورُ", "transliteration": "Al-Ghafur", "englishMeaning": "The All-Forgiving", "explanation": "The One who forgives a lot.", "quranRef": "2:173" },
  { "number": 35, "arabicName": "الشَّكُورُ", "transliteration": "Ash-Shakur", "englishMeaning": "The Most Appreciative", "explanation": "The One who gives a lot of reward for a little obedience.", "quranRef": "35:30" },
  { "number": 36, "arabicName": "العَلِيُّ", "transliteration": "Al-Ali", "englishMeaning": "The Most High", "explanation": "The One who is clear from the attributes of the creation.", "quranRef": "2:255" },
  { "number": 37, "arabicName": "الكَبِيرُ", "transliteration": "Al-Kabir", "englishMeaning": "The Greatest", "explanation": "The One who is greater than everything in status.", "quranRef": "13:9" },
  { "number": 38, "arabicName": "الحَفِيظُ", "transliteration": "Al-Hafiz", "englishMeaning": "The Preserver", "explanation": "The One who protects whatever and whoever He willed to protect.", "quranRef": "11:57" },
  { "number": 39, "arabicName": "المُقِيتُ", "transliteration": "Al-Muqit", "englishMeaning": "The Sustainer", "explanation": "The One who has the power." },
  { "number": 40, "arabicName": "الحَسِيبُ", "transliteration": "Al-Hasib", "englishMeaning": "The Reckoner", "explanation": "The One who gives the satisfaction.", "quranRef": "4:6" },
  { "number": 41, "arabicName": "الجَلِيلُ", "transliteration": "Al-Jalil", "englishMeaning": "The Majestic", "explanation": "The One who is attributed with greatness of power and glory of status." },
  { "number": 42, "arabicName": "الكَرِيمُ", "transliteration": "Al-Karim", "englishMeaning": "The Most Generous", "explanation": "The One who is generous in all aspects.", "quranRef": "27:40" },
  { "number": 43, "arabicName": "الرَّقِيبُ", "transliteration": "Ar-Raqib", "englishMeaning": "The Watchful", "explanation": "The One that nothing is absent from Him.", "quranRef": "4:1" },
  { "number": 44, "arabicName": "المُجِيبُ", "transliteration": "Al-Mujib", "englishMeaning": "The Responsive One", "explanation": "The One who answers the one in need if he asks Him.", "quranRef": "11:61" },
  { "number": 45, "arabicName": "الوَاسِعُ", "transliteration": "Al-Wasi", "englishMeaning": "The All-Encompassing", "explanation": "The Knowledgeable.", "quranRef": "2:268" },
  { "number": 46, "arabicName": "الحَكِيمُ", "transliteration": "Al-Hakim", "englishMeaning": "The All-Wise", "explanation": "The One who is correct in His doings.", "quranRef": "2:129" },
  { "number": 47, "arabicName": "الوَدُودُ", "transliteration": "Al-Wadud", "englishMeaning": "The Most Loving", "explanation": "The One who loves His believing servants and His believing servants love Him.", "quranRef": "11:90" },
  { "number": 48, "arabicName": "المَجِيدُ", "transliteration": "Al-Majid", "englishMeaning": "The Glorious", "explanation": "The One who is with perfect power, high status, compassion, generosity and kindness.", "quranRef": "11:73" },
  { "number": 49, "arabicName": "البَاعِثُ", "transliteration": "Al-Ba'ith", "englishMeaning": "The Resurrector", "explanation": "The One who resurrects His servants after death for reward and/or punishment." },
  { "number": 50, "arabicName": "الشَّهِيدُ", "transliteration": "Ash-Shahid", "englishMeaning": "The All-Witnessing", "explanation": "The One who nothing is absent from Him.", "quranRef": "4:79" },
  { "number": 51, "arabicName": "الحَقُّ", "transliteration": "Al-Haqq", "englishMeaning": "The Absolute Truth", "explanation": "The One who truly exists.", "quranRef": "22:6" },
  { "number": 52, "arabicName": "الوَكِيلُ", "transliteration": "Al-Wakil", "englishMeaning": "The Trustee", "explanation": "The One who gives the satisfaction and is relied upon.", "quranRef": "3:173" },
  { "number": 53, "arabicName": "القَوِيُّ", "transliteration": "Al-Qawi", "englishMeaning": "The All-Strong", "explanation": "The One with the complete power.", "quranRef": "22:40" },
  { "number": 54, "arabicName": "المَتِينُ", "transliteration": "Al-Matin", "englishMeaning": "The Firm One", "explanation": "The One with the extreme power which is un-interrupted.", "quranRef": "51:58" },
  { "number": 55, "arabicName": "الوَلِيُّ", "transliteration": "Al-Wali", "englishMeaning": "The Protecting Associate", "explanation": "The Supporter.", "quranRef": "2:257" },
  { "number": 56, "arabicName": "الحَمِيدُ", "transliteration": "Al-Hamid", "englishMeaning": "The Praiseworthy", "explanation": "The praised One who deserves to be praised.", "quranRef": "14:8" },
  { "number": 57, "arabicName": "المُحْصِي", "transliteration": "Al-Muhsi", "englishMeaning": "The All-Enumerating", "explanation": "The One who the count of things are known to Him." },
  { "number": 58, "arabicName": "المُبْدِئُ", "transliteration": "Al-Mubdi", "englishMeaning": "The Originator", "explanation": "The One who started the human being." },
  { "number": 59, "arabicName": "المُعِيدُ", "transliteration": "Al-Mu'id", "englishMeaning": "The Restorer", "explanation": "The One who brings back the creatures after death." },
  { "number": 60, "arabicName": "المُحْيِي", "transliteration": "Al-Muhyi", "englishMeaning": "The Giver of Life", "explanation": "The One who took out a living human from semen that does not have a soul.", "quranRef": "30:50" },
  { "number": 61, "arabicName": "المُمِيتُ", "transliteration": "Al-Mumit", "englishMeaning": "The Bringer of Death", "explanation": "The One who renders the living dead.", "quranRef": "3:156" },
  { "number": 62, "arabicName": "الحَيُّ", "transliteration": "Al-Hayy", "englishMeaning": "The Ever-Living", "explanation": "The One attributed with a life that is unlike our life.", "quranRef": "2:255" },
  { "number": 63, "arabicName": "القَيُّومُ", "transliteration": "Al-Qayyum", "englishMeaning": "The Sustainer of Existence", "explanation": "The One who remains and does not end.", "quranRef": "2:255" },
  { "number": 64, "arabicName": "الوَاجِدُ", "transliteration": "Al-Wajid", "englishMeaning": "The Perceiver", "explanation": "The Rich who is never poor." },
  { "number": 65, "arabicName": "المَاجِدُ", "transliteration": "Al-Majid", "englishMeaning": "The Illustrious", "explanation": "The One who is Majid." },
  { "number": 66, "arabicName": "الوَاحِدُ", "transliteration": "Al-Wahid", "englishMeaning": "The One", "explanation": "The One without a partner.", "quranRef": "2:163" },
  { "number": 67, "arabicName": "الأَحَدُ", "transliteration": "Al-Ahad", "englishMeaning": "The Unique", "explanation": "The One.", "quranRef": "112:1" },
  { "number": 68, "arabicName": "الصَّمَدُ", "transliteration": "As-Samad", "englishMeaning": "The Eternal Refuge", "explanation": "The Master who is relied upon in matters and reverted to in ones needs.", "quranRef": "112:2" },
  { "number": 69, "arabicName": "القَادِرُ", "transliteration": "Al-Qadir", "englishMeaning": "The All-Powerful", "explanation": "The One attributed with power.", "quranRef": "6:65" },
  { "number": 70, "arabicName": "المُقْتَدِرُ", "transliteration": "Al-Muqtadir", "englishMeaning": "The Creator of All Power", "explanation": "The One with the perfect power.", "quranRef": "54:42" },
  { "number": 71, "arabicName": "المُقَدِّمُ", "transliteration": "Al-Muqaddim", "englishMeaning": "The Expediter", "explanation": "He whom He willed, He brings forward." },
  { "number": 72, "arabicName": "المُؤَخِّرُ", "transliteration": "Al-Mu'akhkhir", "englishMeaning": "The Delayer", "explanation": "The One who delays what He wills." },
  { "number": 73, "arabicName": "الأَوَّلُ", "transliteration": "Al-Awwal", "englishMeaning": "The First", "explanation": "The One whose existence is without a beginning.", "quranRef": "57:3" },
  { "number": 74, "arabicName": "الآخِرُ", "transliteration": "Al-Akhir", "englishMeaning": "The Last", "explanation": "The One whose existence is without an end.", "quranRef": "57:3" },
  { "number": 75, "arabicName": "الظَّاهِرُ", "transliteration": "Az-Zahir", "englishMeaning": "The Manifest", "explanation": "The One above whom nothing exists and whose existence is clear.", "quranRef": "57:3" },
  { "number": 76, "arabicName": "البَاطِنُ", "transliteration": "Al-Batin", "englishMeaning": "The Hidden One", "explanation": "The One below whom nothing exists.", "quranRef": "57:3" },
  { "number": 77, "arabicName": "الوَالِي", "transliteration": "Al-Wali", "englishMeaning": "The Governor", "explanation": "The One who owns things and disposes of them." },
  { "number": 78, "arabicName": "المُتَعَالِي", "transliteration": "Al-Muta'ali", "englishMeaning": "The Self-Exalted", "explanation": "The One who is clear from the attributes of the creation.", "quranRef": "13:9" },
  { "number": 79, "arabicName": "البَرُّ", "transliteration": "Al-Barr", "englishMeaning": "The Source of Goodness", "explanation": "The One who is kind to His creatures, who covered them with His sustenance.", "quranRef": "52:28" },
  { "number": 80, "arabicName": "التَّوَّابُ", "transliteration": "At-Tawwab", "englishMeaning": "The Ever-Accepting of Repentance", "explanation": "The One who grants repentance to whoever He willed.", "quranRef": "2:128" },
  { "number": 81, "arabicName": "المُنْتَقِمُ", "transliteration": "Al-Muntaqim", "englishMeaning": "The Avenger", "explanation": "The One who victoriously prevails over His enemies." },
  { "number": 82, "arabicName": "العَفُوُّ", "transliteration": "Al-Afuw", "englishMeaning": "The Pardoner", "explanation": "The One with wide forgiveness.", "quranRef": "4:99" },
  { "number": 83, "arabicName": "الرَّؤُوفُ", "transliteration": "Ar-Ra'uf", "englishMeaning": "The Most Kind", "explanation": "The One with extreme mercy.", "quranRef": "3:30" },
  { "number": 84, "arabicName": "مَالِكُ المُلْكِ", "transliteration": "Malik-ul-Mulk", "englishMeaning": "Master of the Kingdom", "explanation": "The One who controls the dominion and gives dominion to whoever He willed.", "quranRef": "3:26" },
  { "number": 85, "arabicName": "ذُوالجَلاَلِ وَالإِكْرَامِ", "transliteration": "Dhul-Jalali Wal-Ikram", "englishMeaning": "Lord of Majesty and Generosity", "explanation": "The One who deserves to be Exalted and not denied.", "quranRef": "55:27" },
  { "number": 86, "arabicName": "المُقْسِطُ", "transliteration": "Al-Muqsit", "englishMeaning": "The Equitable One", "explanation": "The One who is Just in His judgment." },
  { "number": 87, "arabicName": "الجَامِعُ", "transliteration": "Al-Jami", "englishMeaning": "The Gatherer", "explanation": "The One who gathers the creatures on a day that there is no doubt about.", "quranRef": "3:9" },
  { "number": 88, "arabicName": "الغَنِيُّ", "transliteration": "Al-Ghani", "englishMeaning": "The Self-Sufficient", "explanation": "The One who does not need the creation.", "quranRef": "2:263" },
  { "number": 89, "arabicName": "المُغْنِي", "transliteration": "Al-Mughni", "englishMeaning": "The Enricher", "explanation": "The One who satisfies the necessities of the creatures." },
  { "number": 90, "arabicName": "المَانِعُ", "transliteration": "Al-Mani", "englishMeaning": "The Withholder", "explanation": "The Supporter who protects and gives victory to His pious believers." },
  { "number": 91, "arabicName": "الضَّارُّ", "transliteration": "Ad-Darr", "englishMeaning": "The Distresser", "explanation": "The One who makes harm reach to whoever He willed." },
  { "number": 92, "arabicName": "النَّافِعُ", "transliteration": "An-Nafi", "englishMeaning": "The Propitious", "explanation": "The One who gives benefit to whoever He wills." },
  { "number": 93, "arabicName": "النُّورُ", "transliteration": "An-Nur", "englishMeaning": "The Light", "explanation": "The One who guides.", "quranRef": "24:35" },
  { "number": 94, "arabicName": "الهَادِي", "transliteration": "Al-Hadi", "englishMeaning": "The Guide", "explanation": "The One whom with His guidance His believers were guided." },
  { "number": 95, "arabicName": "البَدِيعُ", "transliteration": "Al-Badi", "englishMeaning": "The Incomparable Originator", "explanation": "The One who created the creation and formed it without any preceding example.", "quranRef": "2:117" },
  { "number": 96, "arabicName": "البَاقِي", "transliteration": "Al-Baqi", "englishMeaning": "The Everlasting", "explanation": "The One that the state of non-existence is impossible for Him." },
  { "number": 97, "arabicName": "الوَارِثُ", "transliteration": "Al-Warith", "englishMeaning": "The Supreme Inheritor", "explanation": "The One whose existence remains.", "quranRef": "15:23" },
  { "number": 98, "arabicName": "الرَّشِيدُ", "transliteration": "Ar-Rashid", "englishMeaning": "The Guide to the Right Path", "explanation": "The One who guides." },
  { "number": 99, "arabicName": "الصَّبُورُ", "transliteration": "As-Sabur", "englishMeaning": "The Most Patient", "explanation": "The One who does not quickly punish the sinners." }
]
