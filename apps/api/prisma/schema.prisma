  notifyFollows    Boolean @default(true)
  notifyMentions   Boolean @default(true)
  notifyMessages   Boolean @default(true)
  notifyLiveStreams Boolean @default(true)
  emailDigest      Boolean @default(false)
  // Accessibility
  reducedMotion Boolean @default(false)
  largeText     Boolean @default(false)
  highContrast  Boolean @default(false)
  // Wellbeing
  dailyTimeLimit     Int?
  restrictedMode     Boolean @default(false)
  sensitiveContent   Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@map("user_settings")
}

model SubtitleTrack {
  id        String @id @default(cuid())
  videoId   String
  video     Video  @relation(fields: [videoId], references: [id], onDelete: Cascade)
  language  String @db.VarChar(10)
  label     String @db.VarChar(50)
  url       String
  isDefault Boolean @default(false)
  createdAt DateTime @default(now())
  @@index([videoId])
  @@map("subtitle_tracks")
}

model ChannelPost {
  id        String @id @default(cuid())
  channelId String
  channel   Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  content       String  @db.VarChar(5000)
  mediaUrls     String[] @default([])
  likesCount    Int @default(0)
  commentsCount Int @default(0)
  isPinned      Boolean @default(false)
  createdAt     DateTime @default(now())
  @@index([channelId, createdAt(sort: Desc)])
  @@map("channel_posts")
}

model ReelInteraction {
  id     String @id @default(cuid())
  userId String
  reelId String
  viewed          Boolean @default(false)
  watchDurationMs Int     @default(0)
  completionRate  Float?
  liked           Boolean @default(false)
  shared          Boolean @default(false)
  saved           Boolean @default(false)
  createdAt DateTime @default(now())
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  reel Reel @relation(fields: [reelId], references: [id], onDelete: Cascade)
  @@unique([userId, reelId])
  @@index([reelId])
  @@map("reel_interactions")
}

model VideoInteraction {
  id      String @id @default(cuid())
  userId  String
  videoId String
  viewed          Boolean @default(false)
  watchDurationMs Int     @default(0)
  completionRate  Float?
  liked           Boolean @default(false)
  shared          Boolean @default(false)
  saved           Boolean @default(false)
  createdAt DateTime @default(now())
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  video Video @relation(fields: [videoId], references: [id], onDelete: Cascade)
  @@unique([userId, videoId])
  @@index([videoId])
  @@map("video_interactions")
}

// ═══════════════════════════════════════════════════
// BATCH 33: Events, Monetization, Audio Rooms, 2FA
// ═══════════════════════════════════════════════════

model Event {
  id          String   @id @default(cuid())
  title       String   @db.VarChar(200)
  description String?  @db.VarChar(5000)
  coverUrl    String?
  startDate   DateTime
  endDate     DateTime?
  location    String?  @db.VarChar(500)
  locationUrl String?
  isOnline    Boolean  @default(false)
  onlineUrl   String?
  eventType   String   @default("in_person") @db.VarChar(20)
  privacy     String   @default("public") @db.VarChar(20)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  communityId String?
  rsvps       EventRSVP[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@index([userId])
  @@index([startDate(sort: Desc)])
  @@map("events")
}

model EventRSVP {
  id        String   @id @default(cuid())
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  status    String   @db.VarChar(20)
  createdAt DateTime @default(now())
  @@unique([eventId, userId])
  @@index([eventId])
  @@map("event_rsvps")
}

model Tip {
  id          String   @id @default(cuid())
  senderId    String
  receiverId  String
  amount      Float
  currency    String   @default("USD") @db.VarChar(3)
  message     String?  @db.VarChar(500)
  platformFee Float    @default(0)
  status      String   @default("completed") @db.VarChar(20)
  createdAt   DateTime @default(now())
  @@index([senderId])
  @@index([receiverId])
  @@map("tips")
}

model MembershipTier {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name          String   @db.VarChar(100)
  price         Float
  currency      String   @default("USD") @db.VarChar(3)
  benefits      String[] @default([])
  isActive      Boolean  @default(true)
  level         String   @default("bronze") @db.VarChar(10)
  subscriptions MembershipSubscription[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  @@index([userId])
  @@map("membership_tiers")
}

model MembershipSubscription {
  id        String   @id @default(cuid())
  tierId    String
  tier      MembershipTier @relation(fields: [tierId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  status    String   @default("active") @db.VarChar(20)
  startDate DateTime @default(now())
  endDate   DateTime?
  createdAt DateTime @default(now())
  @@unique([tierId, userId])
  @@index([userId])
  @@map("membership_subscriptions")
}

model AudioRoom {
  id           String    @id @default(cuid())
  title        String    @db.VarChar(300)
  description  String?   @db.VarChar(2000)
  hostId       String
  host         User      @relation(fields: [hostId], references: [id], onDelete: Cascade)
  status       String    @default("live") @db.VarChar(20)
  scheduledAt  DateTime?
  startedAt    DateTime?
  endedAt      DateTime?
  maxSpeakers  Int       @default(10)
  isRecording  Boolean   @default(false)
  participants AudioRoomParticipant[]
  createdAt    DateTime  @default(now())
  @@index([hostId])
  @@index([status])
  @@map("audio_rooms")
}

model AudioRoomParticipant {
  id         String    @id @default(cuid())
  roomId     String
  room       AudioRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  role       String    @default("listener") @db.VarChar(20)
  isMuted    Boolean   @default(true)
  handRaised Boolean   @default(false)
  joinedAt   DateTime  @default(now())
  @@unique([roomId, userId])
  @@index([roomId])
  @@map("audio_room_participants")
}

model TwoFactorSecret {
  id          String    @id @default(cuid())
  userId      String    @unique
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  secret      String
  isEnabled   Boolean   @default(false)
  backupCodes String[]  @default([])
  verifiedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  @@map("two_factor_secrets")
}
