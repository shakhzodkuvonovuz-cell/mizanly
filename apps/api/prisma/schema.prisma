model CallParticipant {
  sessionId       String
  userId          String
  role            CallParticipantRole @default(caller)
  joinedAt        DateTime            @default(now())
  leftAt          DateTime?
  livekitJoinedAt DateTime?
  session         CallSession         @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user            User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([sessionId, userId])
  // @@index([sessionId]) — redundant: @@id already has sessionId as leading column
  @@index([userId])
  // [F21 fix] Composite index for active-call lookup: WHERE userId = X AND leftAt IS NULL
  // The active-call query JOINs call_sessions and filters on leftAt IS NULL.
  // Without this, PostgreSQL does a full index scan on userId then filters leftAt in heap.
  // With it, the planner can use the index to skip already-left participants directly.
  @@index([userId, leftAt])
  @@map("call_participants")
}

