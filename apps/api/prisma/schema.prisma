// ============================================================
// E2E ENCRYPTION
// Public keys and conversation key envelopes for end-to-end encryption
// ============================================================

model EncryptionKey {
  id             String   @id @default(cuid())
  userId         String   @unique
  user           User     @relation("encryptionKey", fields: [userId], references: [id], onDelete: Cascade)
  publicKey      String
  keyFingerprint String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("encryption_keys")
}

model ConversationKeyEnvelope {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation("keyEnvelopes", fields: [conversationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation("conversationKeyEnvelopes", fields: [userId], references: [id], onDelete: Cascade)
  encryptedKey   String
  nonce          String
  version        Int          @default(1)
  createdAt      DateTime     @default(now())

  // Race condition prevention: this unique constraint prevents duplicate envelopes
  // for the same (conversation, user, version) tuple. First-message key exchange
  // races are caught by the version=1 duplicate; application should handle the
  // unique violation with a retry/upsert pattern rather than a bare create.
  @@unique([conversationId, userId, version])
  @@index([conversationId])
  @@index([userId])
  @@map("conversation_key_envelopes")
}

// ============================================================
// SIGNAL PROTOCOL — E2E ENCRYPTION (X3DH + Double Ratchet)
// Server is a dumb key store. Never sees plaintext or private keys.
// ============================================================

model E2EIdentityKey {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation("e2eIdentityKey", fields: [userId], references: [id], onDelete: Cascade)
  deviceId       Int      @default(1)
  publicKey      Bytes // 32 bytes Ed25519 public key
  registrationId Int // 14-bit unsigned (0-16383) per Signal spec
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // [G02-C1 fix] Composite unique on (userId, deviceId) for multi-device support.
  // The Go e2e-server does ON CONFLICT ("userId", "deviceId") — this constraint is required.
  @@unique([userId, deviceId])
  @@map("e2e_identity_keys")
}

model E2ESignedPreKey {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation("e2eSignedPreKeys", fields: [userId], references: [id], onDelete: Cascade)
  deviceId  Int      @default(1)
  keyId     Int
  publicKey Bytes // 32 bytes X25519 public key
  signature Bytes // 64 bytes Ed25519 signature over publicKey
  createdAt DateTime @default(now())

  @@unique([userId, deviceId, keyId])
  @@index([userId, deviceId])
  @@map("e2e_signed_pre_keys")
}

model E2EOneTimePreKey {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation("e2eOneTimePreKeys", fields: [userId], references: [id], onDelete: Cascade)
  deviceId  Int      @default(1)
  keyId     Int
  publicKey Bytes // 32 bytes X25519 public key
  // No `used` boolean — rows are DELETED on claim to prevent metadata leak and table bloat
  createdAt DateTime @default(now())

  @@unique([userId, deviceId, keyId])
  @@index([userId, deviceId])
  @@map("e2e_one_time_pre_keys")
}

model E2ESenderKey {
  id              String   @id @default(cuid())
  groupId         String
  senderUserId    String
  recipientUserId String
  senderUser      User     @relation("e2eSenderKeysSent", fields: [senderUserId], references: [id], onDelete: Cascade)
  recipientUser   User     @relation("e2eSenderKeysReceived", fields: [recipientUserId], references: [id], onDelete: Cascade)
  encryptedKey    Bytes
  chainId         Int
  generation      Int      @default(0) // Incremented on member removal rotation
  createdAt       DateTime @default(now())

  @@unique([groupId, senderUserId, recipientUserId, chainId])
  @@index([groupId, recipientUserId])
  @@map("e2e_sender_keys")
}

model HashtagFollow {
  userId    String
  user      User     @relation("hashtagFollows", fields: [userId], references: [id], onDelete: Cascade)
