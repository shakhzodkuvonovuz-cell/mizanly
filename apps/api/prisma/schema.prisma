  mosquePosts              MosquePost[]                @relation("mosquePosts")
  scholarQAs               ScholarQA[]                 @relation("scholarQAs")
  scholarQuestions         ScholarQuestion[]           @relation("scholarQuestions")
  duaBookmarks             DuaBookmark[]               @relation("duaBookmarks")
  hadithBookmarks          HadithBookmark[]            @relation("hadithBookmarks")
  altProfileAccessGrants   AltProfileAccess[]          @relation("altProfileAccess")
  groupTopicsCreated       GroupTopic[]                @relation("groupTopics")
  encryptionKeyRecord      EncryptionKey?              @relation("encryptionKey")
  conversationKeyEnvelopes ConversationKeyEnvelope[]   @relation("conversationKeyEnvelopes")

  // Signal Protocol E2E
  e2eIdentityKeys          E2EIdentityKey[]       @relation("e2eIdentityKey")
  e2eSignedPreKeys         E2ESignedPreKey[]      @relation("e2eSignedPreKeys")
  e2eOneTimePreKeys        E2EOneTimePreKey[]     @relation("e2eOneTimePreKeys")
  e2eSenderKeysSent        E2ESenderKey[]         @relation("e2eSenderKeysSent")
  e2eSenderKeysReceived    E2ESenderKey[]         @relation("e2eSenderKeysReceived")
  adminLogsPerformed       AdminLog[]             @relation("adminLogs")
  adminLogTargets          AdminLog[]             @relation("adminLogTargets")
  storyViews               StoryView[]            @relation("storyViews")
  conversationLastMessages Conversation[]         @relation("conversationLastMessage")
  pinnedMessages           Message[]              @relation("messagePinner")
  reportReviews            Report[]               @relation("reportReviewer")
  altProfileRecord         AltProfile?            @relation("altProfile")
  callScreenShares         CallSession[]          @relation("callScreenShare")
  playlistCollabsAdded     PlaylistCollaborator[] @relation("playlistCollabAdder")
  zakatFundsVerified       ZakatFund[]            @relation("zakatFundVerifier")

  // Batch 5: Dangling FK fixes
  waqfDonations            WaqfDonation[]        @relation("waqfDonations")
  videoCommentLikes        VideoCommentLike[]    @relation("videoCommentLikes")
  scholarQuestionVotes     ScholarQuestionVote[] @relation("scholarQuestionVotes")
  halalVerifyVotes         HalalVerifyVote[]     @relation("halalVerifyVotes")
  starredMessageRecords    StarredMessage[]      @relation("starredMessages")
  adminAuditLogs           AdminAuditLog[]       @relation("adminAuditLogs")
  savedSearches            SavedSearch[]         @relation("savedSearches")
  ownedStickerPacks        StickerPack[]         @relation("ownedStickerPacks")
  audioTracks              AudioTrack[]          @relation("audioTracks")
  fatwaAnswers             FatwaQuestion[]       @relation("FatwaAnswers")
  broadcastChannelsCreated BroadcastChannel[]    @relation("broadcastChannelsCreated")

  // @@index([username]) — redundant: username is @unique
  // @@index([clerkId]) — redundant: clerkId is @unique
  @@index([createdAt(sort: Desc)])
  @@index([previousUsername]) // B01-#8: username reclaim lookup
  @@map("users")
}

// ============================================================
// FOLLOWS
// ============================================================

model Follow {
  followerId  String
  followingId String
  createdAt   DateTime @default(now())
  follower    User     @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)

  @@id([followerId, followingId])
  // @@index([followerId]) — redundant: @@id already has followerId as leading column
  @@index([followingId])
  @@index([createdAt(sort: Desc)])
  @@map("follows")
}

// ============================================================
// SAF (الصف) — THE FEED
// Instagram/Facebook-style posts + Stories
// ============================================================

model Post {
  id                  String            @id @default(cuid())
  userId              String?
  user                User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  content             String?           @db.VarChar(2000)
  postType            PostType          @default(TEXT)
  visibility          PostVisibility    @default(PUBLIC)
  space               ContentSpace      @default(SAF)
  mediaUrls           String[]          @default([])
  mediaTypes          String[]          @default([])
  thumbnailUrl        String?
  mediaWidth          Int?
  mediaHeight         Int?
  videoDuration       Float?
  hashtags            String[]          @default([])
  mentions            String[]          @default([])
  locationName        String?
  locationLat         Float?
  locationLng         Float?
  language            String            @default("en")
  likesCount          Int               @default(0)
  commentsCount       Int               @default(0)
  sharesCount         Int               @default(0)
  savesCount          Int               @default(0)
  viewsCount          Int               @default(0)
  sharedPostId        String?
  sharedPost          Post?             @relation("PostShares", fields: [sharedPostId], references: [id], onDelete: SetNull)
  shares              Post[]            @relation("PostShares")
  circleId            String?
  circle              Circle?           @relation(fields: [circleId], references: [id], onDelete: SetNull)
  isSensitive         Boolean           @default(false)
  altText             String?
  scheduledAt         DateTime?
  originalScheduledAt DateTime? // Preserved when publishOverdueContent sets scheduledAt=null
  hideLikesCount      Boolean           @default(false)
  commentsDisabled    Boolean           @default(false)
  commentPermission   CommentPermission @default(EVERYONE)
  brandedContent      Boolean           @default(false)
  brandPartner        String?
  remixAllowed        Boolean           @default(true)
  shareToFeed         Boolean           @default(true)
  topics              String[]          @default([])
  isDownloadable      Boolean           @default(true)
  isPinned            Boolean           @default(false)
  isFeatured          Boolean           @default(false)
  featuredAt          DateTime?
  blurhash            String?
  isAltProfile        Boolean           @default(false)

  editedAt          DateTime?
  editHistory       Json?
  hiddenFromUserIds String[]          @default([]) // Dangling FK: stores User IDs without relation. Low-volume feature (manual hide per post). Join table deferred.
  expiresAt         DateTime?
  contentHash       String?           @db.VarChar(64)
  isRemoved         Boolean           @default(false)
  removedReason     String?
  removedAt         DateTime?
  removedById       String?
  removedBy         User?             @relation("PostRemover", fields: [removedById], references: [id], onDelete: SetNull)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  comments          Comment[]
  reactions         PostReaction[]
  savedBy           SavedPost[]
  notifications     Notification[]
  feedInteractions  FeedInteraction[]
  moderationLogs    ModerationLog[]   @relation("ModPostTarget")
  collabs           PostCollab[]
  promotions        PostPromotion[]
  reminders         PostReminder[]
  collabInvites     CollabInvite[]    @relation("collabInvites")
  productTags       PostProductTag[]  @relation("productTags")
  reportedInReports Report[]          @relation("reportedPosts")
  seriesEpisodes    SeriesEpisode[]   @relation("seriesEpisodePosts")
  taggedUsers       PostTaggedUser[]

  @@index([userId, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
  @@index([circleId, createdAt(sort: Desc)])
  @@index([space, createdAt(sort: Desc)])
  @@index([hashtags])
  @@index([isFeatured, featuredAt(sort: Desc)])
  @@index([visibility, createdAt(sort: Desc)]) // P0: for-you/trending feeds filter visibility+sort
  @@index([isRemoved, createdAt(sort: Desc)]) // P0: all feeds exclude removed posts
  @@index([isRemoved, visibility, likesCount(sort: Desc)]) // Trending: engagement-sorted candidates
  @@index([isRemoved, visibility, createdAt(sort: Desc)]) // J02-C1: feed queries (isRemoved+visibility filter+sort by date)
  @@index([visibility, isRemoved, likesCount(sort: Desc)]) // J02-C2: search/related posts (visibility-first for search context)
  @@map("posts")
}

model PostTaggedUser {
  id        String            @id @default(cuid())
  postId    String
  post      Post              @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User              @relation("taggedInPosts", fields: [userId], references: [id], onDelete: Cascade)
  positionX Float?
  positionY Float?
  status    TagApprovalStatus @default(PENDING)
  createdAt DateTime          @default(now())

  @@unique([postId, userId])
  @@index([userId])
  @@map("post_tagged_users")
}

model Story {
  id               String                 @id @default(cuid())
  userId           String?
  user             User?                  @relation(fields: [userId], references: [id], onDelete: SetNull)
  mediaUrl         String
  mediaType        String
  thumbnailUrl     String?
  duration         Float?
  textOverlay      String?
  textColor        String?
  bgColor          String?
  musicId          String?
  viewsCount       Int                    @default(0)
  repliesCount     Int                    @default(0)
  expiresAt        DateTime
  isHighlight      Boolean                @default(false)
  highlightName    String?
  highlightAlbumId String?
  highlightAlbum   StoryHighlightAlbum?   @relation(fields: [highlightAlbumId], references: [id], onDelete: SetNull)
  stickerData      Json?
  blurhash         String?
  closeFriendsOnly Boolean                @default(false)
  subscribersOnly  Boolean                @default(false)
  isSensitive      Boolean                @default(false)
  isArchived       Boolean                @default(false)
  isRemoved        Boolean                @default(false) // S01-#7: soft-delete for moderation
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt // S01-#20: mutation tracking
  views            StoryView[]
  stickerResponses StoryStickerResponse[]
  chainEntries     StoryChainEntry[]

  @@index([userId, createdAt(sort: Desc)])
  @@index([expiresAt])
  @@index([highlightAlbumId]) // B07-#12: highlight album queries
  @@map("stories")
}

model StoryView {
  storyId   String
  viewerId  String
  viewer    User     @relation("storyViews", fields: [viewerId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  story     Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)

  @@id([storyId, viewerId])
  @@index([viewerId])
  @@map("story_views")
}

// ============================================================
// BAKRA (بكرة) — SHORT VIDEO
// TikTok-style vertical swipe, 15s-3min
// ============================================================

model Reel {
  id                  String            @id @default(cuid())
  userId              String?
  user                User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  videoUrl            String
  streamId            String?
  hlsUrl              String?
  dashUrl             String?
  qualities           String[]          @default([])
  isLooping           Boolean           @default(true)
  normalizeAudio      Boolean           @default(false)
  thumbnailUrl        String?
  duration            Float
  width               Int               @default(1080)
  height              Int               @default(1920)
  status              ReelStatus        @default(PROCESSING)
  caption             String?           @db.VarChar(500)
  hashtags            String[]          @default([])
  mentions            String[]          @default([])
  language            String            @default("en")
  audioId             String?
  audioTitle          String?
  audioArtist         String?
  audioTrackId        String?
  audioTrack          AudioTrack?       @relation(fields: [audioTrackId], references: [id], onDelete: SetNull)
  duetOfId            String?
  duetOf              Reel?             @relation("DuetOf", fields: [duetOfId], references: [id], onDelete: SetNull)
  stitchOfId          String?
  stitchOf            Reel?             @relation("StitchOf", fields: [stitchOfId], references: [id], onDelete: SetNull)
  isDuet              Boolean           @default(false)
  isStitch            Boolean           @default(false)
  isPhotoCarousel     Boolean           @default(false)
  carouselUrls        String[]          @default([])
  carouselTexts       String[]          @default([])
  altText             String?
  locationName        String?
  locationLat         Float?
  locationLng         Float?
  commentPermission   CommentPermission @default(EVERYONE)
  brandedContent      Boolean           @default(false)
  brandPartner        String?
  remixAllowed        Boolean           @default(true)
  topics              String[]          @default([])
  scheduledAt         DateTime?
  originalScheduledAt DateTime?
  blurhash            String?
  likesCount          Int               @default(0)
  commentsCount       Int               @default(0)
  sharesCount         Int               @default(0)
  savesCount          Int               @default(0)
  viewsCount          Int               @default(0)
  loopsCount          Int               @default(0)
  isFeatureWorthy     Boolean           @default(false)
  isTrial             Boolean           @default(false)
  isSensitive         Boolean           @default(false)
  isArchived          Boolean           @default(false)
  isRemoved           Boolean           @default(false)
  removedReason       String?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  reactions           ReelReaction[]
  comments            ReelComment[]
  interactions        ReelInteraction[]
  notifications       Notification[]
  duets               Reel[]            @relation("DuetOf")
  stitches            Reel[]            @relation("StitchOf")
  templates           ReelTemplate[]    @relation("ReelTemplateSource")
  seriesEpisodes      SeriesEpisode[]   @relation("seriesEpisodeReels")
  taggedUsers         ReelTaggedUser[]
  feedInteractions    FeedInteraction[] @relation("feedInteractionReel")

  @@index([userId, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
  @@index([viewsCount(sort: Desc)])
  @@index([hashtags])
  @@index([status, createdAt(sort: Desc)]) // P0: feed queries filter status=READY+sort
  @@index([isRemoved, createdAt(sort: Desc)]) // P0: all feeds exclude removed reels
  @@index([status, isRemoved, isTrial, createdAt(sort: Desc)]) // ForYou feed composite filter
  @@index([status, isRemoved, likesCount(sort: Desc)]) // J02-C3: search/trending reels by engagement
  @@index([status, isRemoved, viewsCount(sort: Desc)]) // J02-C4: trending reels by views
  @@map("reels")
}

model ReelTaggedUser {
  id        String            @id @default(cuid())
  reelId    String
  reel      Reel              @relation(fields: [reelId], references: [id], onDelete: Cascade)
  userId    String
  user      User              @relation("taggedInReels", fields: [userId], references: [id], onDelete: Cascade)
  status    TagApprovalStatus @default(PENDING)
  createdAt DateTime          @default(now())

  @@unique([reelId, userId])
  @@index([userId])
  @@map("reel_tagged_users")
}

model ReelReaction {
  userId    String
  reelId    String
  reaction  ReactionType @default(LIKE)
  createdAt DateTime     @default(now())
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  reel      Reel         @relation(fields: [reelId], references: [id], onDelete: Cascade)

  @@id([userId, reelId])
  @@index([reelId])
  @@map("reel_reactions")
}

model ReelComment {
  id         String                @id @default(cuid())
  reelId     String
  userId     String
  reel       Reel                  @relation(fields: [reelId], references: [id], onDelete: Cascade)
  user       User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  parentId   String?
  parent     ReelComment?          @relation("ReelCommentThread", fields: [parentId], references: [id], onDelete: Cascade)
  replies    ReelComment[]         @relation("ReelCommentThread")
  reactions  ReelCommentReaction[]
  content    String                @db.VarChar(500)
  likesCount Int                   @default(0)
  isRemoved  Boolean               @default(false) // S01-#11: soft-delete for moderation
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @updatedAt // S01-#9: edit tracking

  @@index([reelId, createdAt])
  @@index([parentId])
  @@index([userId]) // S01-#14 equivalent: GDPR export + "my comments" queries
  @@map("reel_comments")
}

model ReelCommentReaction {
  userId    String
  commentId String
  reaction  ReactionType @default(LIKE)
  createdAt DateTime     @default(now())
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  comment   ReelComment  @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@id([userId, commentId])
  @@index([commentId])
  @@map("reel_comment_reactions")
}

// ============================================================
// MAJLIS (المجلس) — TEXT & DISCUSSION
// X/Twitter-style threads + microblogging
// ============================================================

model Thread {
  id                  String            @id @default(cuid())
  userId              String?
  user                User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  content             String            @db.VarChar(500)
  mediaUrls           String[]          @default([])
  mediaTypes          String[]          @default([])
  isChainHead         Boolean           @default(true)
  chainId             String?
  chainPosition       Int               @default(0)
  repostOfId          String?
  repostOf            Thread?           @relation("ThreadReposts", fields: [repostOfId], references: [id], onDelete: SetNull)
  reposts             Thread[]          @relation("ThreadReposts")
  isQuotePost         Boolean           @default(false)
  quoteText           String?           @db.VarChar(500)
  hashtags            String[]          @default([])
  mentions            String[]          @default([])
  language            String            @default("en")
  visibility          ThreadVisibility  @default(PUBLIC)
  circleId            String?
  circle              Circle?           @relation(fields: [circleId], references: [id], onDelete: SetNull)
  likesCount          Int               @default(0)
  repliesCount        Int               @default(0)
  repostsCount        Int               @default(0)
  quotesCount         Int               @default(0)
  viewsCount          Int               @default(0)
  bookmarksCount      Int               @default(0)
  isPinned            Boolean           @default(false)
  isSensitive         Boolean           @default(false)
  altText             String?
  scheduledAt         DateTime?
  originalScheduledAt DateTime?
  hideLikesCount      Boolean           @default(false)
  isRemoved           Boolean           @default(false)
  replyPermission     ReplyPermission   @default(EVERYONE)
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  reactions           ThreadReaction[]
  replies             ThreadReply[]
  poll                Poll?
  bookmarks           ThreadBookmark[]
  notifications       Notification[]
  feedInteractions    FeedInteraction[] @relation("feedInteractionThread")

  @@index([userId, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
  @@index([chainId])
  @@index([circleId, createdAt(sort: Desc)])
  @@index([hashtags])
  @@index([isChainHead, createdAt(sort: Desc)]) // P0: thread feeds filter chain heads+sort
  @@index([isRemoved, visibility, likesCount(sort: Desc)]) // Trending: engagement-sorted candidates
  @@index([isRemoved, visibility, isChainHead, likesCount(sort: Desc)]) // J02-C5: search/trending chain-head threads
  @@map("threads")
}

model ThreadReaction {
  userId    String
  threadId  String
  reaction  ReactionType @default(LIKE)
  createdAt DateTime     @default(now())
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  thread    Thread       @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@id([userId, threadId])
  @@index([threadId])
  @@map("thread_reactions")
}

model ThreadReply {
  id         String            @id @default(cuid())
  threadId   String
  userId     String
  thread     Thread            @relation(fields: [threadId], references: [id], onDelete: Cascade)
  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  parentId   String?
  parent     ThreadReply?      @relation("ThreadReplyChain", fields: [parentId], references: [id], onDelete: Cascade)
  replies    ThreadReply[]     @relation("ThreadReplyChain")
  content    String            @db.VarChar(500)
  mediaUrls  String[]          @default([])
  likesCount Int               @default(0)
  isRemoved  Boolean           @default(false) // S01-#10: soft-delete for moderation
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt // S01-#9: edit tracking
  likes      ThreadReplyLike[]

  @@index([threadId, createdAt])
  @@index([parentId])
  @@map("thread_replies")
}

model ThreadReplyLike {
  userId    String
  replyId   String
  createdAt DateTime    @default(now())
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  reply     ThreadReply @relation(fields: [replyId], references: [id], onDelete: Cascade)

  @@id([userId, replyId])
  @@index([replyId])
  @@map("thread_reply_likes")
}

// ============================================================
// MINBAR (المنبر) — LONG VIDEO
// YouTube-style horizontal video, channels, playlists
// ============================================================

model Channel {
  id                 String              @id @default(cuid())
  userId             String?             @unique
  user               User?               @relation(fields: [userId], references: [id], onDelete: SetNull)
  handle             String              @unique
  name               String              @db.VarChar(100)
  description        String?             @db.VarChar(5000)
  avatarUrl          String?
  bannerUrl          String?
  subscribersCount   BigInt              @default(0) // S01-#43: overflow protection
  videosCount        Int                 @default(0)
  totalViews         BigInt              @default(0) // S01-#3: overflow protection
  isMonetized        Boolean             @default(false)
  isVerified         Boolean             @default(false)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  videos             Video[]
  playlists          Playlist[]
  subscribers        Subscription[]
  channelPosts       ChannelPost[]
  trailerVideoId     String?
  viewerDemographics ViewerDemographic[] @relation("viewerDemographics")

  // @@index([handle]) — redundant: handle is @unique
  @@index([subscribersCount(sort: Desc)])
  @@map("channels")
}

model Video {
  id                  String              @id @default(cuid())
  userId              String?
  channelId           String
  user                User?               @relation(fields: [userId], references: [id], onDelete: SetNull)
  channel             Channel             @relation(fields: [channelId], references: [id], onDelete: Cascade)
  title               String              @db.VarChar(200)
  description         String?             @db.VarChar(10000)
  videoUrl            String
  streamId            String?
  hlsUrl              String?
  dashUrl             String?
  qualities           String[]            @default([])
  isLooping           Boolean             @default(false)
  normalizeAudio      Boolean             @default(false)
  thumbnailUrl        String?
  blurhash            String?
  duration            Float
  width               Int?
  height              Int?
  status              VideoStatus         @default(DRAFT)
  category            VideoCategory       @default(OTHER)
  tags                String[]            @default([])
  language            String              @default("en")
  chapters            Json?
  viewsCount          Int                 @default(0)
  likesCount          Int                 @default(0)
  dislikesCount       Int                 @default(0)
  commentsCount       Int                 @default(0)
  sharesCount         Int                 @default(0)
  savesCount          Int                 @default(0)
  avgWatchDuration    Float?
  completionRate      Float?
  isRemoved           Boolean             @default(false)
  isAgeRestricted     Boolean             @default(false)
  isPremiereEnabled   Boolean             @default(false)
  scheduledAt         DateTime?
  originalScheduledAt DateTime?
  publishedAt         DateTime?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  comments            VideoComment[]
  reactions           VideoReaction[]
  playlistItems       PlaylistItem[]
  subtitles           SubtitleTrack[]
  bookmarks           VideoBookmark[]
  interactions        VideoInteraction[]
  watchLater          WatchLater[]
  watchHistory        WatchHistory[]
  notifications       Notification[]
  premiere            VideoPremiere?
  clips               VideoClip[]
  endScreens          EndScreen[]
  aiCaptions          AiCaption[]
  videoChapters       VideoChapter[]      @relation("videoChapters")
  watchParties        WatchParty[]        @relation("watchParties")
  viewerDemographics  ViewerDemographic[] @relation("viewerDemographics")
  seriesEpisodes      SeriesEpisode[]     @relation("seriesEpisodeVideos")

  @@index([channelId, publishedAt(sort: Desc)])
  @@index([status, publishedAt(sort: Desc)])
  @@index([status, createdAt(sort: Desc)])
  @@index([status, isRemoved, createdAt(sort: Desc)])
  @@index([category, viewsCount(sort: Desc)])
  @@index([tags])
  @@index([userId]) // B05-#25: user's videos lookup
  @@index([status, isRemoved, viewsCount(sort: Desc)]) // J02-C6: video search/trending by views
  @@map("videos")
}

model VideoComment {
  id         String             @id @default(cuid())
  videoId    String
  userId     String
  video      Video              @relation(fields: [videoId], references: [id], onDelete: Cascade)
  user       User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  parentId   String?
  parent     VideoComment?      @relation("VideoCommentThread", fields: [parentId], references: [id], onDelete: Cascade)
  replies    VideoComment[]     @relation("VideoCommentThread")
  content    String             @db.VarChar(2000)
  likesCount Int                @default(0)
  timestamp  Float?
  isPinned   Boolean            @default(false)
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt // S01-#13: edit tracking
  likes      VideoCommentLike[] @relation("videoCommentLikes")

  @@index([videoId, createdAt])
  @@index([parentId])
  @@index([userId]) // S01-#14: GDPR export + user comment lookups
  @@map("video_comments")
}

model VideoReaction {
  userId    String
  videoId   String
  isLike    Boolean
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  video     Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@id([userId, videoId])
  @@index([videoId])
  // @@index([userId]) — redundant: @@id already has userId as leading column
  @@map("video_reactions")
}

model Subscription {
  userId          String
  channelId       String
  notificationsOn Boolean  @default(true)
  createdAt       DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel         Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@id([userId, channelId])
  @@index([channelId])
  @@map("subscriptions")
}

model Playlist {
  id              String                 @id @default(cuid())
  channelId       String
  channel         Channel                @relation(fields: [channelId], references: [id], onDelete: Cascade)
  title           String                 @db.VarChar(200)
  description     String?                @db.VarChar(1000)
  thumbnailUrl    String?
  isPublic        Boolean                @default(true)
  isCollaborative Boolean                @default(false)
  videosCount     Int                    @default(0)
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  items           PlaylistItem[]
  collaborators   PlaylistCollaborator[]

  @@index([channelId])
  @@map("playlists")
}

model PlaylistItem {
  id         String   @id @default(cuid())
  playlistId String
  videoId    String
  position   Int
  playlist   Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  video      Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([playlistId, videoId])
  @@index([playlistId, position])
  @@map("playlist_items")
}

// ============================================================
// SAF COMMENTS
// ============================================================

model Comment {
  id              String            @id @default(cuid())
  postId          String
  post            Post              @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId          String
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  parentId        String?
  parent          Comment?          @relation("CommentThread", fields: [parentId], references: [id], onDelete: Cascade)
  replies         Comment[]         @relation("CommentThread")
  content         String            @db.VarChar(1000)
  mentions        String[]          @default([])
  likesCount      Int               @default(0)
  repliesCount    Int               @default(0)
  isPinned        Boolean           @default(false)
  isRemoved       Boolean           @default(false)
  isHidden        Boolean           @default(false)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  reactions       CommentReaction[]
  notifications   Notification[]
  moderationLogs  ModerationLog[]   @relation("ModCommentTarget")
  reportedReports Report[]          @relation("reportedComments")

  @@index([postId, createdAt])
  @@index([userId, createdAt(sort: Desc)])
  @@index([parentId])
  @@map("comments")
}

model PostReaction {
  userId    String
  postId    String
  reaction  ReactionType @default(LIKE)
  createdAt DateTime     @default(now())
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      Post         @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@id([userId, postId])
  @@index([postId])
  @@map("post_reactions")
}

model CommentReaction {
  userId    String
  commentId String
  reaction  ReactionType @default(LIKE)
  createdAt DateTime     @default(now())
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  comment   Comment      @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@id([userId, commentId])
  @@index([commentId])
  // @@index([userId]) — redundant: @@id already has userId as leading column
  @@map("comment_reactions")
}

model SavedPost {
  userId         String
  postId         String
  collectionName String   @default("default")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt // S01-#27: collection reassignment tracking
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post           Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@id([userId, postId])
  @@index([userId, createdAt(sort: Desc)])
  @@index([postId]) // B02-#18: saved count on post
  @@map("saved_posts")
}

// ============================================================
// RISALAH (رسالة) — MESSAGING
// ============================================================

model Conversation {
  id                    String    @id @default(cuid())
  isGroup               Boolean   @default(false)
  groupName             String?
  groupDescription      String?   @db.VarChar(500)
  groupAvatarUrl        String?
  createdById           String?
  createdBy             User?     @relation("ConversationCreator", fields: [createdById], references: [id], onDelete: SetNull)
  lastMessageText       String?
  lastMessageAt         DateTime?
  lastMessageById       String?
  lastMessageBy         User?     @relation("conversationLastMessage", fields: [lastMessageById], references: [id], onDelete: SetNull)
  disappearingDuration  Int?
  slowModeSeconds       Int? // 0 = off, 30, 60, 300, 900, 3600
  lockCode              String? // Secret code to unlock this conversation
  genderRestriction     String?   @db.VarChar(10) // Finding #395: null=mixed, 'male', 'female'
  newMemberHistoryCount Int?      @default(25) // Number of recent messages shown to new members (0-100)
  inviteCode            String?   @db.VarChar(32) // Shareable group invite code (DB backup for Redis cache)
  inviteExpiresAt       DateTime? // When the invite link expires

  // Signal Protocol E2E — client-encrypted preview for conversation list
  encryptedLastMessagePreview Bytes?
  // V6-F2b: Persistent E2E flag — set on first encrypted message, never unset.
  // Once true, the server rejects plaintext messages in this conversation.
  // Replaces Redis TTL-based check (which expired after 24h, allowing delayed injection).
  isE2E                       Boolean @default(false)

  createdAt     DateTime                  @default(now())
  updatedAt     DateTime                  @updatedAt
  members       ConversationMember[]
  messages      Message[]
  notifications Notification[]
  adminLogs     AdminLog[]
  groupTopics   GroupTopic[]
  checklists    MessageChecklist[]
  keyEnvelopes  ConversationKeyEnvelope[] @relation("keyEnvelopes")

  @@index([lastMessageAt(sort: Desc)])
  @@index([createdById]) // B06-#13: admin/creator conversation lookup
  @@map("conversations")
}

model ConversationMember {
  conversationId String
  userId         String
  lastReadAt     DateTime         @default(now())
  lastMessageAt  DateTime? // Denormalized for per-member conversation ordering
  unreadCount    Int              @default(0)
  isMuted        Boolean          @default(false)
  isPinned       Boolean          @default(false)
  isArchived     Boolean          @default(false)
  role           ConversationRole @default(member)
  isBanned       Boolean          @default(false)
  customTone     String?
  wallpaperUrl   String?
  tag            String?          @db.VarChar(30)
  joinedAt       DateTime         @default(now())
  conversation   Conversation     @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([conversationId, userId])
  @@index([userId])
  @@index([userId, lastMessageAt(sort: Desc)])
  @@map("conversation_members")
}

model Message {
  id              String      @id @default(cuid())
  conversationId  String
  senderId        String?
  content         String?     @db.VarChar(5000)
  messageType     MessageType @default(TEXT)
  mediaUrl        String?
  mediaType       String?
  voiceDuration   Float?
  fileName        String?
  fileSize        Int?
  replyToId       String?
  replyTo         Message?    @relation("MessageReply", fields: [replyToId], references: [id], onDelete: SetNull)
  replies         Message[]   @relation("MessageReply")
  deliveredAt     DateTime?
  isForwarded     Boolean     @default(false)
  forwardedFromId String?
  forwardedFrom   Message?    @relation("MessageForwardedFrom", fields: [forwardedFromId], references: [id], onDelete: SetNull)
  forwardCount    Int         @default(0)
  editableUntil   DateTime?
  expiresAt       DateTime?
  isDeleted       Boolean     @default(false)
  editedAt        DateTime?
  isScheduled     Boolean     @default(false)
  scheduledAt     DateTime?
  starredBy       String[]    @default([]) // @deprecated — use StarredMessage join table instead. Kept for migration compatibility.
  isPinned        Boolean     @default(false)
  pinnedAt        DateTime?
  pinnedById      String?
  pinnedBy        User?       @relation("messagePinner", fields: [pinnedById], references: [id], onDelete: SetNull)
  isViewOnce      Boolean     @default(false)
  viewedAt        DateTime?
  isSpoiler       Boolean     @default(false)
  isSilent        Boolean     @default(false)
  isEncrypted     Boolean     @default(false)
  transcription   String?
  encNonce        String?

  // Signal Protocol E2E fields
  encryptedContent    Bytes? // Raw binary ciphertext (avoids base64 overhead)
  e2eVersion          Int? // 1=classical X3DH, 2=PQXDH (future), 3=sealed sender (future)
  e2eSenderDeviceId   Int? // Sender device for multi-device session routing
  e2eSenderRatchetKey Bytes? // 32 bytes: sender's current DH ratchet public key
  e2eCounter          Int? // Message counter in current sending chain
  e2ePreviousCounter  Int? // Last counter in previous sending chain
  e2eSenderKeyId      Int? // For group messages: sender key chain identifier
  clientMessageId     String? @unique // Client-generated UUID for idempotent dedup

  createdAt       DateTime          @default(now())
  conversation    Conversation      @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender          User?             @relation(fields: [senderId], references: [id], onDelete: SetNull)
  moderationLogs  ModerationLog[]   @relation("ModMessageTarget")
  reactions       MessageReaction[]
  reportedReports Report[]          @relation("reportedMessages")
  starredRecords  StarredMessage[]  @relation("starredMessages")
  forwardedCopies Message[]         @relation("MessageForwardedFrom")

  @@index([conversationId, createdAt(sort: Desc)])
  @@index([conversationId, isPinned, isDeleted]) // J02-C7: pinned messages query (replaces B06-#14, adds isDeleted filter)
  @@index([senderId])
  @@index([expiresAt])
  @@index([scheduledAt])
  @@index([conversationId, senderId, createdAt(sort: Desc)]) // J02-C8: slow mode check (last message by sender in conversation)
  @@index([isScheduled, scheduledAt]) // J02-C9: scheduled message cron job
  @@map("messages")
}

model BroadcastChannel {
  id               String             @id @default(cuid())
  name             String             @db.VarChar(100)
  slug             String             @unique
  description      String?            @db.VarChar(1000)
  avatarUrl        String?
  channelType      ChannelType        @default(BROADCAST)
  subscribersCount Int                @default(0)
  postsCount       Int                @default(0)
  createdById      String? // R2: owner/creator FK (nullable for existing rows)
  createdBy        User?              @relation("broadcastChannelsCreated", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  members          ChannelMember[]
  messages         BroadcastMessage[]

  // @@index([slug]) — redundant: slug is @unique
  @@index([createdById]) // R2: owner lookup
  @@map("broadcast_channels")
}

model ChannelMember {
  channelId String
  userId    String
  role      ChannelRole      @default(SUBSCRIBER)
  isMuted   Boolean          @default(false)
  joinedAt  DateTime         @default(now())
  updatedAt DateTime         @updatedAt // S01-#23: role/mute mutation tracking
  channel   BroadcastChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([channelId, userId])
  @@index([userId])
  @@map("channel_members")
}

model BroadcastMessage {
  id             String           @id @default(cuid())
  channelId      String
  senderId       String?
  content        String?          @db.VarChar(5000)
  messageType    MessageType      @default(TEXT)
  mediaUrl       String?
  mediaType      String?
  viewsCount     Int              @default(0)
  reactionsCount Int              @default(0)
  isPinned       Boolean          @default(false)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  channel        BroadcastChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  sender         User?            @relation(fields: [senderId], references: [id], onDelete: SetNull)

  @@index([channelId, createdAt(sort: Desc)])
  @@map("broadcast_messages")
}

// ============================================================
// LIVE SESSIONS (Video Streams + Audio Spaces)
// ============================================================

model LiveSession {
  id                String            @id @default(cuid())
  hostId            String
  host              User              @relation("LiveHost", fields: [hostId], references: [id], onDelete: Cascade)
  title             String            @db.VarChar(200)
  description       String?           @db.VarChar(1000)
  thumbnailUrl      String?
  liveType          LiveType
  status            LiveStatus        @default(SCHEDULED)
  streamKey         String?           @unique
  playbackUrl       String?
  streamId          String?
  peakViewers       BigInt            @default(0) // S01-#26: overflow protection for viral sessions
  currentViewers    BigInt            @default(0) // S01-#26: overflow protection
  totalViews        Int               @default(0)
  scheduledAt       DateTime?
  startedAt         DateTime?
  endedAt           DateTime?
  recordingUrl      String?
  isRecorded        Boolean           @default(true)
  isRehearsal       Boolean           @default(false)
  isSubscribersOnly Boolean           @default(false)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  participants      LiveParticipant[]
  guests            LiveGuest[]

  @@index([hostId, createdAt(sort: Desc)])
  @@index([status])
  @@index([liveType, status])
  @@map("live_sessions")
}

model LiveParticipant {
  sessionId String
  userId    String
  role      LiveRole    @default(VIEWER)
  joinedAt  DateTime    @default(now())
  leftAt    DateTime?
  updatedAt DateTime    @updatedAt // S01-#25: role transition tracking
  session   LiveSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([sessionId, userId])
  // @@index([sessionId]) — redundant: @@id already has sessionId as leading column
  @@index([userId])
  @@map("live_participants")
}

model LiveGuest {
  id        String          @id @default(cuid())
  liveId    String
  userId    String
  status    LiveGuestStatus @default(INVITED)
  joinedAt  DateTime?
  leftAt    DateTime?
  createdAt DateTime        @default(now())
  live      LiveSession     @relation(fields: [liveId], references: [id], onDelete: Cascade)
  user      User            @relation("LiveGuest", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([liveId, userId])
  @@index([liveId, status])
  @@map("live_guests")
}

enum LiveGuestStatus {
  INVITED
  ACCEPTED
  REMOVED
}

// ============================================================
// SAF CIRCLES (Communities)
// ============================================================

model Circle {
  id                  String              @id @default(cuid())
  name                String              @db.VarChar(100)
  slug                String              @unique
  description         String?             @db.VarChar(1000)
  avatarUrl           String?
  coverUrl            String?
  privacy             CirclePrivacy       @default(PUBLIC)
  ownerId             String
  owner               User                @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  membersCount        Int                 @default(1)
  postsCount          Int                 @default(0)
  rules               String?
  isBanned            Boolean             @default(false)
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  posts               Post[]
  threads             Thread[]
  members             CircleMember[]
  invites             CircleInvite[]
  notifications       Notification[]
  communityRoles      CommunityRole[]     @relation("communityRoles")
  forumThreads        ForumThread[]       @relation("forumThreads")
  webhooks            Webhook[]           @relation("webhooks")
  stageSessions       StageSession[]      @relation("stageSessions")
  communityEvents     Event[]             @relation("communityEvents")
  communityTreasuries CommunityTreasury[] @relation("communityTreasuries")

  // @@index([slug]) — redundant: slug is @unique
  @@index([ownerId])
  @@index([privacy, membersCount(sort: Desc)])
  @@map("circles")
}

model CircleMember {
  circleId  String
  userId    String
  role      CircleRole @default(MEMBER)
  joinedAt  DateTime   @default(now())
  updatedAt DateTime   @updatedAt // S01-#24: role change tracking
  circle    Circle     @relation(fields: [circleId], references: [id], onDelete: Cascade)
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([circleId, userId])
  @@index([userId])
  @@map("circle_members")
}

model CircleInvite {
  id          String    @id @default(cuid())
  circleId    String
  code        String    @unique @default(cuid())
  createdById String
  maxUses     Int       @default(0)
  useCount    Int       @default(0)
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt // S01-#39: invite mutation tracking
  circle      Circle    @relation(fields: [circleId], references: [id], onDelete: Cascade)
  createdBy   User      @relation(fields: [createdById], references: [id], onDelete: Cascade)

  @@index([circleId])
  @@index([createdById])
  @@map("circle_invites")
}

// ============================================================
// NOTIFICATIONS
// ============================================================

model Notification {
  id              String           @id @default(cuid())
  userId          String
  actorId         String?
  type            NotificationType
  postId          String?
  commentId       String?
  circleId        String?
  conversationId  String?
  threadId        String?
  reelId          String?
  videoId         String?
  followRequestId String?
  title           String?
  body            String?
  isRead          Boolean          @default(false)
  readAt          DateTime?
  createdAt       DateTime         @default(now())
  user            User             @relation("NotificationRecipient", fields: [userId], references: [id], onDelete: Cascade)
  actor           User?            @relation("NotificationActor", fields: [actorId], references: [id], onDelete: Cascade)
  post            Post?            @relation(fields: [postId], references: [id], onDelete: Cascade)
  comment         Comment?         @relation(fields: [commentId], references: [id], onDelete: Cascade)
  circle          Circle?          @relation(fields: [circleId], references: [id], onDelete: Cascade)
  conversation    Conversation?    @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  thread          Thread?          @relation(fields: [threadId], references: [id], onDelete: Cascade)
  reel            Reel?            @relation(fields: [reelId], references: [id], onDelete: Cascade)
  video           Video?           @relation(fields: [videoId], references: [id], onDelete: Cascade)
  followRequest   FollowRequest?   @relation(fields: [followRequestId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, isRead])
  @@index([userId, type, createdAt(sort: Desc)])
  @@index([actorId])
  @@index([postId])
  @@index([reelId])
  @@index([threadId])
  @@index([videoId])
  @@map("notifications")
}

// ============================================================
// REPORTS & MODERATION
// ============================================================

model Report {
  id                    String           @id @default(cuid())
  reporterId            String?
  reportedUserId        String?
  reportedPostId        String?
  reportedPost          Post?            @relation("reportedPosts", fields: [reportedPostId], references: [id], onDelete: SetNull)
  reportedCommentId     String?
  reportedComment       Comment?         @relation("reportedComments", fields: [reportedCommentId], references: [id], onDelete: SetNull)
  reportedMessageId     String?
  reportedMessage       Message?         @relation("reportedMessages", fields: [reportedMessageId], references: [id], onDelete: SetNull)
  reportedThreadId      String?
  reportedReelId        String?
  reportedVideoId       String?
  reason                ReportReason
  description           String?          @db.VarChar(1000)
  status                ReportStatus     @default(PENDING)
  reviewedById          String?
  reviewedBy            User?            @relation("reportReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  reviewedAt            DateTime?
  actionTaken           ModerationAction @default(NONE)
  moderatorNotes        String?
  explanationToReporter String?
  explanationToReported String?
  createdAt             DateTime         @default(now())
  reporter              User?            @relation("Reporter", fields: [reporterId], references: [id], onDelete: SetNull)
  reportedUser          User?            @relation("ReportedUser", fields: [reportedUserId], references: [id], onDelete: SetNull)
  moderationLogs        ModerationLog[]

  // B11-#7: prevent duplicate reports (same reporter + same target)
  // Prisma nullable unique: multiple NULLs allowed, only non-null values deduplicated
  @@unique([reporterId, reportedPostId])
  @@unique([reporterId, reportedCommentId])
  @@unique([reporterId, reportedMessageId])
  @@unique([reporterId, reportedThreadId])
  @@unique([reporterId, reportedReelId])
  @@unique([reporterId, reportedVideoId])
  @@unique([reporterId, reportedUserId])
  @@index([status, createdAt])
  @@index([reportedUserId])
  @@index([reporterId])
  @@index([reportedThreadId])
  @@index([reportedReelId])
  @@index([reportedVideoId])
  @@index([reportedPostId]) // B11-#9: FK index for post reports
  @@index([reportedCommentId]) // B11-#9: FK index for comment reports
  @@index([reportedMessageId]) // B11-#9: FK index for message reports
  @@index([reviewedById]) // B11-#9: reviewer lookup
  @@map("reports")
}

model ModerationLog {
  id              String           @id @default(cuid())
  moderatorId     String?
  targetUserId    String?
  targetPostId    String?
  targetCommentId String?
  targetMessageId String?
  action          ModerationAction
  reason          String
  explanation     String
  reportId        String?
  isAppealed      Boolean          @default(false)
  appealText      String?
  appealResolved  Boolean?
  appealResult    String?
  isAutoFlagged   Boolean          @default(false) // B11-#15: auto-moderation tracking
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt // B11-#22: mutation tracking
  moderator       User?            @relation("Moderator", fields: [moderatorId], references: [id], onDelete: SetNull)
  targetUser      User?            @relation("ModTarget", fields: [targetUserId], references: [id], onDelete: SetNull)
  targetPost      Post?            @relation("ModPostTarget", fields: [targetPostId], references: [id], onDelete: SetNull)
  targetComment   Comment?         @relation("ModCommentTarget", fields: [targetCommentId], references: [id], onDelete: SetNull)
  targetMessage   Message?         @relation("ModMessageTarget", fields: [targetMessageId], references: [id], onDelete: SetNull)
  report          Report?          @relation(fields: [reportId], references: [id], onDelete: SetNull)

  @@index([targetUserId, createdAt(sort: Desc)])
  @@index([reportId])
  @@index([moderatorId])
  @@index([isAppealed, appealResolved]) // B11-#11: appeal queue queries
  @@index([action, createdAt(sort: Desc)]) // B11-#9: action type filtering
  @@map("moderation_log")
}

// ============================================================
// BLOCKS & MUTES
// ============================================================

model Block {
  blockerId String
  blockedId String
  createdAt DateTime @default(now())
  blocker   User     @relation("Blocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked   User     @relation("Blocked", fields: [blockedId], references: [id], onDelete: Cascade)

  @@id([blockerId, blockedId])
  @@index([blockedId])
  @@index([blockerId]) // P0: feed exclusion queries filter by blockerId
  @@map("blocks")
}

model Mute {
  userId    String
  mutedId   String
  createdAt DateTime @default(now())
  user      User     @relation("Muter", fields: [userId], references: [id], onDelete: Cascade)
  muted     User     @relation("Muted", fields: [mutedId], references: [id], onDelete: Cascade)

  @@id([userId, mutedId])
  @@index([mutedId])
  @@index([userId]) // P0: feed exclusion queries filter by userId
  @@map("mutes")
}

// ============================================================
// HASHTAGS
// ============================================================

model Hashtag {
  id           String   @id @default(cuid())
  name         String   @unique
  postsCount   Int      @default(0)
  reelsCount   Int      @default(0)
  threadsCount Int      @default(0)
  videosCount  Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // @@index([name]) — redundant: name is @unique
  @@index([postsCount(sort: Desc)])
  @@map("hashtags")
}

// ============================================================
// FEED ALGORITHM SIGNALS
// ============================================================

model FeedInteraction {
  id             String       @id @default(cuid())
  userId         String
  postId         String?
  reelId         String?
  threadId       String?
  space          ContentSpace @default(SAF)
  viewed         Boolean      @default(false)
  viewDurationMs Int          @default(0)
  liked          Boolean      @default(false)
  commented      Boolean      @default(false)
  shared         Boolean      @default(false)
  saved          Boolean      @default(false)
  completionRate Float?
  createdAt      DateTime     @default(now())
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  post           Post?        @relation(fields: [postId], references: [id], onDelete: Cascade)
  reel           Reel?        @relation("feedInteractionReel", fields: [reelId], references: [id], onDelete: Cascade)
