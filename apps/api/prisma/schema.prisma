// ============================================================
// USER & PROFILE
// ============================================================

model User {
  id               String  @id @default(cuid())
  clerkId          String  @unique
  email            String  @unique
  username         String  @unique
  previousUsername String?
  displayName      String
  bio              String  @default("") @db.VarChar(500)
  avatarUrl        String?
  avatarBlurhash   String?
  coverUrl         String?
  coverBlurhash    String?
  website          String?
  location         String?
  phone            String?

  followersCount Int @default(0)
  followingCount Int @default(0)
  postsCount     Int @default(0)
  threadsCount   Int @default(0)
  reelsCount     Int @default(0)

  role            UserRole @default(USER)
  isVerified      Boolean  @default(false)
  isPrivate       Boolean  @default(false)
  pronouns        String?  @db.VarChar(30)
  statusText      String?  @db.VarChar(100)
  language        String   @default("en")
  theme           String   @default("system")
  expoPushToken   String?
  notificationsOn Boolean  @default(true)

  isBanned        Boolean   @default(false)
  banReason       String?
  banExpiresAt    DateTime?
  warningsCount   Int       @default(0)
  reputationScore Int       @default(100)
  isMemorialized  Boolean   @default(false) // Finding #267: Deceased account memorialization

  isScholarVerified Boolean          @default(false)
  nasheedMode       Boolean          @default(false)
  creatorCategory   CreatorCategory? // S01-#44: was String, closed set per DTO @IsIn

  // Legal/compliance
  tosAcceptedAt DateTime?
  tosVersion    String?   @db.VarChar(20)

  // Referral system (Finding #326)
  referralCode String? @unique @db.VarChar(12)
  referredBy   String? // userId of the person who referred this user

  // Monetization — balance is in CoinBalance table (NOT on User model)
  stripeConnectAccountId String?
  madhab                 String?  @db.VarChar(20)
  lastActiveAt           DateTime @default(now())

  isDeactivated       Boolean   @default(false)
  deactivatedAt       DateTime?
  isDeleted           Boolean   @default(false)
  deletedAt           DateTime?
  scheduledDeletionAt DateTime?

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  lastSeenAt DateTime @default(now())

  // Saf
  posts            Post[]
  taggedInPosts    PostTaggedUser[]  @relation("taggedInPosts")
  stories          Story[]
  comments         Comment[]
  postReactions    PostReaction[]
  commentReactions CommentReaction[]
  savedPosts       SavedPost[]

  // Bakra
  reels                Reel[]
  taggedInReels        ReelTaggedUser[]      @relation("taggedInReels")
  reelReactions        ReelReaction[]
  reelComments         ReelComment[]
  reelCommentReactions ReelCommentReaction[]

  // Majlis
  threads          Thread[]
  threadReactions  ThreadReaction[]
  threadReplies    ThreadReply[]
  threadReplyLikes ThreadReplyLike[]

  // Minbar
  channel        Channel?
  videos         Video[]
  videoComments  VideoComment[]
  videoReactions VideoReaction[]
  subscriptions  Subscription[]

  // Risalah
  sentMessages            Message[]
  conversationMemberships ConversationMember[]
  channelMemberships      ChannelMember[]
  broadcastMessages       BroadcastMessage[]

  // Live
  hostedLives        LiveSession[]     @relation("LiveHost")
  liveParticipations LiveParticipant[]

  // Shared
  notifications        Notification[]    @relation("NotificationRecipient")
  actedNotifications   Notification[]    @relation("NotificationActor")
  ownedCircles         Circle[]
  circleMemberships    CircleMember[]
  circleInvitesCreated CircleInvite[]
  reports              Report[]          @relation("Reporter")
  reportedReports      Report[]          @relation("ReportedUser")
  moderationActions    ModerationLog[]   @relation("Moderator")
  moderationTargets    ModerationLog[]   @relation("ModTarget")
  feedInteractions     FeedInteraction[]
  followers            Follow[]          @relation("Following")
  following            Follow[]          @relation("Follower")
  blockedUsers         Block[]           @relation("Blocker")
  blockedBy            Block[]           @relation("Blocked")
  mutedUsers           Mute[]            @relation("Muter")
  mutedBy              Mute[]            @relation("Muted")
  removedPosts         Post[]            @relation("PostRemover")
  createdConversations Conversation[]    @relation("ConversationCreator")

  // New relations (Week 1 additions)
  followRequests         FollowRequest[]        @relation("SentFollowRequests")
  receivedFollowRequests FollowRequest[]        @relation("ReceivedFollowRequests")
  interests              UserInterest[]
  feedDismissals         FeedDismissal[]
  draftPosts             DraftPost[]
  profileLinks           ProfileLink[]
  devices                Device[]
  callParticipations     CallParticipant[]
  stickerPacks           UserStickerPack[]
  majlisLists            MajlisList[]
  majlisListMemberships  MajlisListMember[]
  postCollabs            PostCollab[]
  blockedKeywords        BlockedKeyword[]
  creatorStats           CreatorStat[]
  settings               UserSettings?
  threadBookmarks        ThreadBookmark[]
  videoBookmarks         VideoBookmark[]
  watchHistory           WatchHistory[]
  watchLater             WatchLater[]
  messageReactions       MessageReaction[]
  storyHighlightAlbums   StoryHighlightAlbum[]
  storyStickerResponses  StoryStickerResponse[]
  pollVotes              PollVote[]
  channelPosts           ChannelPost[]
