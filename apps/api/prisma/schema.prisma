// ============================================================
// EMBEDDINGS — pgvector-based content similarity
// ============================================================

enum EmbeddingContentType {
  POST
  REEL
  THREAD
  VIDEO
}

model Embedding {
  id          String                     @id @default(uuid())
  contentId   String
  contentType EmbeddingContentType
  vector      Unsupported("vector(768)")
  metadata    Json?
  postId      String?
  userId      String?
  createdAt   DateTime                   @default(now())
  updatedAt   DateTime                   @updatedAt

  @@unique([contentId, contentType])
  @@index([contentType])
  @@index([contentType, contentId])
  @@index([postId])
  @@index([userId])
  @@map("embeddings")
}

