  @@id([storyId, viewerId])
  @@index([viewerId])
  @@map("story_views")
}

// ============================================================
// BAKRA (بكرة) — SHORT VIDEO
// TikTok-style vertical swipe, 15s-3min
// ============================================================

model Reel {
  id              String            @id @default(cuid())
  userId          String?
  user            User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  videoUrl        String
  streamId        String?
  hlsUrl          String?
  dashUrl         String?
  qualities       String[]          @default([])
  isLooping       Boolean           @default(true)
  normalizeAudio  Boolean           @default(false)
  thumbnailUrl    String?
  duration        Float
  width           Int               @default(1080)
  height          Int               @default(1920)
  status          ReelStatus        @default(PROCESSING)
  caption         String?           @db.VarChar(500)
  hashtags        String[]          @default([])
  mentions        String[]          @default([])
  language        String            @default("en")
  audioId         String?
  audioTitle      String?
  audioArtist     String?
  audioTrackId    String?
  audioTrack      AudioTrack?       @relation(fields: [audioTrackId], references: [id], onDelete: SetNull)
  duetOfId        String?
  duetOf          Reel?             @relation("DuetOf", fields: [duetOfId], references: [id], onDelete: SetNull)
  stitchOfId      String?
  stitchOf        Reel?             @relation("StitchOf", fields: [stitchOfId], references: [id], onDelete: SetNull)
  isDuet          Boolean           @default(false)
  isStitch        Boolean           @default(false)
  isPhotoCarousel   Boolean           @default(false)
  carouselUrls      String[]          @default([])
  carouselTexts     String[]          @default([])
  altText           String?
  locationName      String?
  locationLat       Float?
  locationLng       Float?
  commentPermission CommentPermission @default(EVERYONE)
  brandedContent    Boolean           @default(false)
  brandPartner      String?
  remixAllowed      Boolean           @default(true)
  topics            String[]          @default([])
  scheduledAt       DateTime?
  blurhash          String?
  likesCount      Int               @default(0)
  commentsCount   Int               @default(0)
  sharesCount     Int               @default(0)
  savesCount      Int               @default(0)
  viewsCount      Int               @default(0)
  loopsCount      Int               @default(0)
  isFeatureWorthy Boolean           @default(false)
  isSensitive     Boolean           @default(false)
  isArchived      Boolean           @default(false)
  isRemoved       Boolean           @default(false)
  removedReason   String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  reactions       ReelReaction[]
  comments        ReelComment[]
  interactions    ReelInteraction[]
  notifications   Notification[]
  duets           Reel[]            @relation("DuetOf")
  stitches        Reel[]            @relation("StitchOf")
  templates       ReelTemplate[]    @relation("ReelTemplateSource")
  seriesEpisodes  SeriesEpisode[]   @relation("seriesEpisodeReels")
  taggedUsers     ReelTaggedUser[]

  @@index([userId, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
  @@index([viewsCount(sort: Desc)])
  @@index([hashtags])
  @@map("reels")
}

model ReelTaggedUser {
  id        String            @id @default(cuid())
  reelId    String
  reel      Reel              @relation(fields: [reelId], references: [id], onDelete: Cascade)
  userId    String
  user      User              @relation("taggedInReels", fields: [userId], references: [id], onDelete: Cascade)
  status    TagApprovalStatus @default(PENDING)
  createdAt DateTime          @default(now())

  @@unique([reelId, userId])
  @@index([userId])
  @@map("reel_tagged_users")
}

model ReelReaction {
  userId    String
  reelId    String
  reaction  ReactionType @default(LIKE)
  createdAt DateTime     @default(now())
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  reel      Reel         @relation(fields: [reelId], references: [id], onDelete: Cascade)

  @@id([userId, reelId])
  @@index([reelId])
  @@map("reel_reactions")
}

model ReelComment {
  id         String                @id @default(cuid())
  reelId     String
  userId     String
  reel       Reel                  @relation(fields: [reelId], references: [id], onDelete: Cascade)
  user       User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  parentId   String?
  parent     ReelComment?          @relation("ReelCommentThread", fields: [parentId], references: [id], onDelete: Cascade)
  replies    ReelComment[]         @relation("ReelCommentThread")
  reactions  ReelCommentReaction[]
  content    String                @db.VarChar(500)
  likesCount Int                   @default(0)
  createdAt  DateTime              @default(now())

  @@index([reelId, createdAt])
  @@index([parentId])
  @@map("reel_comments")
}

model ReelCommentReaction {
  userId    String
  commentId String
  reaction  ReactionType @default(LIKE)
  createdAt DateTime     @default(now())
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  comment   ReelComment  @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@id([userId, commentId])
  @@index([commentId])
  @@map("reel_comment_reactions")
}

// ============================================================
// MAJLIS (المجلس) — TEXT & DISCUSSION
// X/Twitter-style threads + microblogging
// ============================================================

model Thread {
  id              String           @id @default(cuid())
  userId          String?
  user            User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  content         String           @db.VarChar(500)
  mediaUrls       String[]         @default([])
  mediaTypes      String[]         @default([])
  isChainHead     Boolean          @default(true)
  chainId         String?
  chainPosition   Int              @default(0)
  repostOfId      String?
  repostOf        Thread?          @relation("ThreadReposts", fields: [repostOfId], references: [id], onDelete: SetNull)
  reposts         Thread[]         @relation("ThreadReposts")
  isQuotePost     Boolean          @default(false)
  quoteText       String?          @db.VarChar(500)
  hashtags        String[]         @default([])
  mentions        String[]         @default([])
  language        String           @default("en")
  visibility      ThreadVisibility @default(PUBLIC)
  circleId        String?
  circle          Circle?          @relation(fields: [circleId], references: [id], onDelete: SetNull)
  likesCount      Int              @default(0)
  repliesCount    Int              @default(0)
  repostsCount    Int              @default(0)
  quotesCount     Int              @default(0)
  viewsCount      Int              @default(0)
  bookmarksCount  Int              @default(0)
  isPinned        Boolean          @default(false)
  isSensitive     Boolean          @default(false)
  altText         String?
  scheduledAt     DateTime?
  hideLikesCount  Boolean          @default(false)
  isRemoved       Boolean          @default(false)
  replyPermission ReplyPermission  @default(EVERYONE)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  reactions       ThreadReaction[]
  replies         ThreadReply[]
  poll            Poll?
  bookmarks       ThreadBookmark[]
  notifications   Notification[]

  @@index([userId, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
  @@index([chainId])
  @@index([circleId, createdAt(sort: Desc)])
  @@index([hashtags])
  @@map("threads")
}

model ThreadReaction {
  userId    String
  threadId  String
  reaction  ReactionType @default(LIKE)
  createdAt DateTime     @default(now())
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  thread    Thread       @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@id([userId, threadId])
  @@index([threadId])
  @@map("thread_reactions")
}

model ThreadReply {
  id         String            @id @default(cuid())
  threadId   String
  userId     String
  thread     Thread            @relation(fields: [threadId], references: [id], onDelete: Cascade)
  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  parentId   String?
  parent     ThreadReply?      @relation("ThreadReplyChain", fields: [parentId], references: [id], onDelete: Cascade)
  replies    ThreadReply[]     @relation("ThreadReplyChain")
  content    String            @db.VarChar(500)
  mediaUrls  String[]          @default([])
  likesCount Int               @default(0)
  createdAt  DateTime          @default(now())
  likes      ThreadReplyLike[]

  @@index([threadId, createdAt])
  @@index([parentId])
  @@map("thread_replies")
}

model ThreadReplyLike {
  userId    String
  replyId   String
  createdAt DateTime    @default(now())
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  reply     ThreadReply @relation(fields: [replyId], references: [id], onDelete: Cascade)

  @@id([userId, replyId])
  @@index([replyId])
  @@map("thread_reply_likes")
}

// ============================================================
// MINBAR (المنبر) — LONG VIDEO
// YouTube-style horizontal video, channels, playlists
// ============================================================

model Channel {
  id                 String              @id @default(cuid())
  userId             String?             @unique
  user               User?               @relation(fields: [userId], references: [id], onDelete: SetNull)
  handle             String              @unique
  name               String              @db.VarChar(100)
  description        String?             @db.VarChar(5000)
  avatarUrl          String?
  bannerUrl          String?
  subscribersCount   Int                 @default(0)
  videosCount        Int                 @default(0)
  totalViews         Int                 @default(0)
  isMonetized        Boolean             @default(false)
  isVerified         Boolean             @default(false)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  videos             Video[]
  playlists          Playlist[]
  subscribers        Subscription[]
  channelPosts       ChannelPost[]
  trailerVideoId     String?
  viewerDemographics ViewerDemographic[] @relation("viewerDemographics")

  @@index([handle])
  @@index([subscribersCount(sort: Desc)])
  @@map("channels")
}

model Video {
  id                 String              @id @default(cuid())
  userId             String?
  channelId          String
  user               User?               @relation(fields: [userId], references: [id], onDelete: SetNull)
  channel            Channel             @relation(fields: [channelId], references: [id], onDelete: Cascade)
  title              String              @db.VarChar(200)
  description        String?             @db.VarChar(10000)
  videoUrl           String
  streamId           String?
  hlsUrl             String?
  dashUrl            String?
  qualities          String[]            @default([])
  isLooping          Boolean             @default(false)
  normalizeAudio     Boolean             @default(false)
  thumbnailUrl       String?
  blurhash           String?
  duration           Float
  width              Int?
  height             Int?
  status             VideoStatus         @default(DRAFT)
  category           VideoCategory       @default(OTHER)
  tags               String[]            @default([])
  language           String              @default("en")
  chapters           Json?
  viewsCount         Int                 @default(0)
  likesCount         Int                 @default(0)
  dislikesCount      Int                 @default(0)
  commentsCount      Int                 @default(0)
  sharesCount        Int                 @default(0)
  savesCount         Int                 @default(0)
  avgWatchDuration   Float?
  completionRate     Float?
  isRemoved          Boolean             @default(false)
  isAgeRestricted    Boolean             @default(false)
  isPremiereEnabled  Boolean             @default(false)
  scheduledAt        DateTime?
  publishedAt        DateTime?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  comments           VideoComment[]
  reactions          VideoReaction[]
  playlistItems      PlaylistItem[]
  subtitles          SubtitleTrack[]
  bookmarks          VideoBookmark[]
  interactions       VideoInteraction[]
  watchLater         WatchLater[]
  watchHistory       WatchHistory[]
  notifications      Notification[]
  premiere           VideoPremiere?
  clips              VideoClip[]
  endScreens         EndScreen[]
  aiCaptions         AiCaption[]
  videoChapters      VideoChapter[]      @relation("videoChapters")
  watchParties       WatchParty[]        @relation("watchParties")
  viewerDemographics ViewerDemographic[] @relation("viewerDemographics")
  seriesEpisodes     SeriesEpisode[]     @relation("seriesEpisodeVideos")

  @@index([channelId, publishedAt(sort: Desc)])
  @@index([status, publishedAt(sort: Desc)])
  @@index([category, viewsCount(sort: Desc)])
  @@index([tags])
  @@map("videos")
}

model VideoComment {
  id         String         @id @default(cuid())
  videoId    String
  userId     String
  video      Video          @relation(fields: [videoId], references: [id], onDelete: Cascade)
  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  parentId   String?
  parent     VideoComment?  @relation("VideoCommentThread", fields: [parentId], references: [id], onDelete: Cascade)
  replies    VideoComment[] @relation("VideoCommentThread")
  content    String             @db.VarChar(2000)
  likesCount Int                @default(0)
  timestamp  Float?
  isPinned   Boolean            @default(false)
  createdAt  DateTime           @default(now())
  likes      VideoCommentLike[] @relation("videoCommentLikes")

  @@index([videoId, createdAt])
  @@index([parentId])
  @@map("video_comments")
}

model VideoReaction {
  userId    String
  videoId   String
  isLike    Boolean
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  video     Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@id([userId, videoId])
  @@index([videoId])
  // @@index([userId]) — redundant: @@id already has userId as leading column
  @@map("video_reactions")
}

model Subscription {
  userId          String
  channelId       String
  notificationsOn Boolean  @default(true)
  createdAt       DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel         Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@id([userId, channelId])
  @@index([channelId])
  @@map("subscriptions")
}

model Playlist {
  id              String                 @id @default(cuid())
  channelId       String
  channel         Channel                @relation(fields: [channelId], references: [id], onDelete: Cascade)
  title           String                 @db.VarChar(200)
  description     String?                @db.VarChar(1000)
  thumbnailUrl    String?
  isPublic        Boolean                @default(true)
  isCollaborative Boolean                @default(false)
  videosCount     Int                    @default(0)
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  items           PlaylistItem[]
  collaborators   PlaylistCollaborator[]

  @@index([channelId])
  @@map("playlists")
}

model PlaylistItem {
  id         String   @id @default(cuid())
  playlistId String
  videoId    String
  position   Int
  playlist   Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  video      Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([playlistId, videoId])
  @@index([playlistId, position])
  @@map("playlist_items")
}

// ============================================================
// SAF COMMENTS
// ============================================================

model Comment {
  id              String            @id @default(cuid())
  postId          String
  post            Post              @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId          String
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  parentId        String?
  parent          Comment?          @relation("CommentThread", fields: [parentId], references: [id], onDelete: Cascade)
  replies         Comment[]         @relation("CommentThread")
  content         String            @db.VarChar(1000)
  mentions        String[]          @default([])
  likesCount      Int               @default(0)
  repliesCount    Int               @default(0)
  isPinned        Boolean           @default(false)
  isRemoved       Boolean           @default(false)
  isHidden        Boolean           @default(false)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  reactions       CommentReaction[]
  notifications   Notification[]
  moderationLogs  ModerationLog[]   @relation("ModCommentTarget")
  reportedReports Report[]          @relation("reportedComments")

  @@index([postId, createdAt])
  @@index([userId, createdAt(sort: Desc)])
  @@index([parentId])
  @@map("comments")
}

model PostReaction {
  userId    String
  postId    String
  reaction  ReactionType @default(LIKE)
  createdAt DateTime     @default(now())
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      Post         @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@id([userId, postId])
  @@index([postId])
  @@map("post_reactions")
}

model CommentReaction {
  userId    String
  commentId String
  reaction  ReactionType @default(LIKE)
  createdAt DateTime     @default(now())
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  comment   Comment      @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@id([userId, commentId])
  @@index([commentId])
  // @@index([userId]) — redundant: @@id already has userId as leading column
  @@map("comment_reactions")
}

model SavedPost {
  userId         String
  postId         String
  collectionName String   @default("default")
  createdAt      DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post           Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@id([userId, postId])
  @@index([userId, createdAt(sort: Desc)])
  @@map("saved_posts")
}

// ============================================================
// RISALAH (رسالة) — MESSAGING
// ============================================================

model Conversation {
  id                    String                    @id @default(cuid())
  isGroup               Boolean                   @default(false)
  groupName             String?
  groupAvatarUrl        String?
  createdById           String?
  createdBy             User?                     @relation("ConversationCreator", fields: [createdById], references: [id], onDelete: SetNull)
  lastMessageText       String?
  lastMessageAt         DateTime?
  lastMessageById       String?
  lastMessageBy         User?                     @relation("conversationLastMessage", fields: [lastMessageById], references: [id], onDelete: SetNull)
  disappearingDuration  Int?
  slowModeSeconds       Int? // 0 = off, 30, 60, 300, 900, 3600
  lockCode              String? // Secret code to unlock this conversation
  newMemberHistoryCount Int?                      @default(25) // Number of recent messages shown to new members (0-100)
  createdAt             DateTime                  @default(now())
  updatedAt             DateTime                  @updatedAt
  members               ConversationMember[]
  messages              Message[]
  notifications         Notification[]
  adminLogs             AdminLog[]
  groupTopics           GroupTopic[]
  checklists            MessageChecklist[]
  keyEnvelopes          ConversationKeyEnvelope[] @relation("keyEnvelopes")

  @@index([lastMessageAt(sort: Desc)])
  @@map("conversations")
}

model ConversationMember {
  conversationId String
  userId         String
  lastReadAt     DateTime     @default(now())
  unreadCount    Int          @default(0)
  isMuted        Boolean      @default(false)
  isArchived     Boolean      @default(false)
  role           String       @default("member") @db.VarChar(10)
  isBanned       Boolean      @default(false)
  customTone     String?
  wallpaperUrl   String?
  tag            String?      @db.VarChar(30)
  joinedAt       DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([conversationId, userId])
  @@index([userId])
  @@map("conversation_members")
}

model Message {
  id              String            @id @default(cuid())
  conversationId  String
  senderId        String?
  content         String?           @db.VarChar(5000)
  messageType     MessageType       @default(TEXT)
  mediaUrl        String?
  mediaType       String?
  voiceDuration   Float?
  fileName        String?
  fileSize        Int?
  replyToId       String?
  replyTo         Message?          @relation("MessageReply", fields: [replyToId], references: [id], onDelete: SetNull)
  replies         Message[]         @relation("MessageReply")
  deliveredAt     DateTime?
  isForwarded     Boolean           @default(false)
  forwardedFromId String?
  forwardedFrom   Message?          @relation("MessageForwardedFrom", fields: [forwardedFromId], references: [id], onDelete: SetNull)
  forwardCount    Int               @default(0)
  editableUntil   DateTime?
  expiresAt       DateTime?
  isDeleted       Boolean           @default(false)
  editedAt        DateTime?
  isScheduled     Boolean           @default(false)
  scheduledAt     DateTime?
  starredBy       String[]          @default([]) // @deprecated — use StarredMessage join table instead. Kept for migration compatibility.
  isPinned        Boolean           @default(false)
  pinnedAt        DateTime?
  pinnedById      String?
  pinnedBy        User?             @relation("messagePinner", fields: [pinnedById], references: [id], onDelete: SetNull)
  isViewOnce      Boolean           @default(false)
  viewedAt        DateTime?
  isSpoiler       Boolean           @default(false)
  isSilent        Boolean           @default(false)
  isEncrypted     Boolean           @default(false)
  transcription   String?
  encNonce        String?
  createdAt       DateTime          @default(now())
  conversation    Conversation      @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender          User?             @relation(fields: [senderId], references: [id], onDelete: SetNull)
  moderationLogs  ModerationLog[]   @relation("ModMessageTarget")
  reactions       MessageReaction[]
  reportedReports Report[]          @relation("reportedMessages")
  starredRecords  StarredMessage[]  @relation("starredMessages")
  forwardedCopies Message[]         @relation("MessageForwardedFrom")

  @@index([conversationId, createdAt(sort: Desc)])
  @@index([senderId])
  @@index([expiresAt])
  @@index([scheduledAt])
  @@map("messages")
}

model BroadcastChannel {
  id               String             @id @default(cuid())
  name             String             @db.VarChar(100)
  slug             String             @unique
  description      String?            @db.VarChar(1000)
  avatarUrl        String?
  channelType      ChannelType        @default(BROADCAST)
  subscribersCount Int                @default(0)
  postsCount       Int                @default(0)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  members          ChannelMember[]
  messages         BroadcastMessage[]

  @@index([slug])
  @@map("broadcast_channels")
}

model ChannelMember {
  channelId String
  userId    String
  role      ChannelRole      @default(SUBSCRIBER)
  isMuted   Boolean          @default(false)
  joinedAt  DateTime         @default(now())
  channel   BroadcastChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([channelId, userId])
  @@index([userId])
  @@map("channel_members")
}

model BroadcastMessage {
  id             String           @id @default(cuid())
  channelId      String
  senderId       String?
  content        String?          @db.VarChar(5000)
  messageType    MessageType      @default(TEXT)
  mediaUrl       String?
  mediaType      String?
  viewsCount     Int              @default(0)
  reactionsCount Int              @default(0)
  isPinned       Boolean          @default(false)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  channel        BroadcastChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  sender         User?            @relation(fields: [senderId], references: [id], onDelete: SetNull)

  @@index([channelId, createdAt(sort: Desc)])
  @@map("broadcast_messages")
}

// ============================================================
// LIVE SESSIONS (Video Streams + Audio Spaces)
// ============================================================

model LiveSession {
  id                String            @id @default(cuid())
  hostId            String
  host              User              @relation("LiveHost", fields: [hostId], references: [id], onDelete: Cascade)
  title             String            @db.VarChar(200)
  description       String?           @db.VarChar(1000)
  thumbnailUrl      String?
  liveType          LiveType
  status            LiveStatus        @default(SCHEDULED)
  streamKey         String?           @unique
  playbackUrl       String?
  streamId          String?
  peakViewers       Int               @default(0)
  currentViewers    Int               @default(0)
  totalViews        Int               @default(0)
  scheduledAt       DateTime?
  startedAt         DateTime?
  endedAt           DateTime?
  recordingUrl      String?
  isRecorded        Boolean           @default(true)
  isRehearsal       Boolean           @default(false)
  isSubscribersOnly Boolean           @default(false)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  participants      LiveParticipant[]
  guests            LiveGuest[]

  @@index([hostId, createdAt(sort: Desc)])
  @@index([status])
  @@index([liveType, status])
  @@map("live_sessions")
}

model LiveParticipant {
  sessionId String
  userId    String
  role      LiveRole    @default(VIEWER)
  joinedAt  DateTime    @default(now())
  leftAt    DateTime?
  session   LiveSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([sessionId, userId])
  // @@index([sessionId]) — redundant: @@id already has sessionId as leading column
  @@index([userId])
  @@map("live_participants")
}

model LiveGuest {
  id        String          @id @default(cuid())
  liveId    String
  userId    String
  status    LiveGuestStatus @default(INVITED)
  joinedAt  DateTime?
  leftAt    DateTime?
  createdAt DateTime        @default(now())
  live      LiveSession     @relation(fields: [liveId], references: [id], onDelete: Cascade)
  user      User            @relation("LiveGuest", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([liveId, userId])
  @@index([liveId, status])
  @@map("live_guests")
}

enum LiveGuestStatus {
  INVITED
  ACCEPTED
  REMOVED
}

// ============================================================
// SAF CIRCLES (Communities)
// ============================================================

model Circle {
  id                  String              @id @default(cuid())
  name                String              @db.VarChar(100)
  slug                String              @unique
  description         String?             @db.VarChar(1000)
  avatarUrl           String?
  coverUrl            String?
  privacy             CirclePrivacy       @default(PUBLIC)
  ownerId             String
  owner               User                @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  membersCount        Int                 @default(1)
  postsCount          Int                 @default(0)
  rules               String?
  isBanned            Boolean             @default(false)
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  posts               Post[]
  threads             Thread[]
  members             CircleMember[]
  invites             CircleInvite[]
  notifications       Notification[]
  communityRoles      CommunityRole[]     @relation("communityRoles")
  forumThreads        ForumThread[]       @relation("forumThreads")
  webhooks            Webhook[]           @relation("webhooks")
  stageSessions       StageSession[]      @relation("stageSessions")
  communityEvents     Event[]             @relation("communityEvents")
  communityTreasuries CommunityTreasury[] @relation("communityTreasuries")

  @@index([slug])
  @@index([ownerId])
  @@index([privacy, membersCount(sort: Desc)])
  @@map("circles")
}

model CircleMember {
  circleId String
  userId   String
  role     CircleRole @default(MEMBER)
  joinedAt DateTime   @default(now())
  circle   Circle     @relation(fields: [circleId], references: [id], onDelete: Cascade)
  user     User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([circleId, userId])
  @@index([userId])
  @@map("circle_members")
}

model CircleInvite {
  id          String    @id @default(cuid())
  circleId    String
  code        String    @unique @default(cuid())
  createdById String
  maxUses     Int       @default(0)
  useCount    Int       @default(0)
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  circle      Circle    @relation(fields: [circleId], references: [id], onDelete: Cascade)
  createdBy   User      @relation(fields: [createdById], references: [id], onDelete: Cascade)

  @@index([circleId])
  @@index([createdById])
  @@map("circle_invites")
}

// ============================================================
// NOTIFICATIONS
// ============================================================

model Notification {
  id              String           @id @default(cuid())
  userId          String
  actorId         String?
  type            NotificationType
  postId          String?
  commentId       String?
  circleId        String?
  conversationId  String?
  threadId        String?
  reelId          String?
  videoId         String?
  followRequestId String?
  title           String?
  body            String?
  isRead          Boolean          @default(false)
  readAt          DateTime?
  createdAt       DateTime         @default(now())
  user            User             @relation("NotificationRecipient", fields: [userId], references: [id], onDelete: Cascade)
  actor           User?            @relation("NotificationActor", fields: [actorId], references: [id], onDelete: Cascade)
  post            Post?            @relation(fields: [postId], references: [id], onDelete: Cascade)
  comment         Comment?         @relation(fields: [commentId], references: [id], onDelete: Cascade)
  circle          Circle?          @relation(fields: [circleId], references: [id], onDelete: Cascade)
  conversation    Conversation?    @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  thread          Thread?          @relation(fields: [threadId], references: [id], onDelete: Cascade)
  reel            Reel?            @relation(fields: [reelId], references: [id], onDelete: Cascade)
  video           Video?           @relation(fields: [videoId], references: [id], onDelete: Cascade)
  followRequest   FollowRequest?   @relation(fields: [followRequestId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, isRead])
  @@index([actorId])
  @@index([postId])
  @@index([reelId])
  @@index([threadId])
  @@index([videoId])
  @@map("notifications")
}

// ============================================================
// REPORTS & MODERATION
// ============================================================

model Report {
  id                    String           @id @default(cuid())
  reporterId            String?
  reportedUserId        String?
  reportedPostId        String?
  reportedPost          Post?            @relation("reportedPosts", fields: [reportedPostId], references: [id], onDelete: SetNull)
  reportedCommentId     String?
  reportedComment       Comment?         @relation("reportedComments", fields: [reportedCommentId], references: [id], onDelete: SetNull)
  reportedMessageId     String?
  reportedMessage       Message?         @relation("reportedMessages", fields: [reportedMessageId], references: [id], onDelete: SetNull)
  reportedThreadId      String?
  reportedReelId        String?
  reportedVideoId       String?
  reason                ReportReason
  description           String?          @db.VarChar(1000)
  status                ReportStatus     @default(PENDING)
  reviewedById          String?
  reviewedBy            User?            @relation("reportReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  reviewedAt            DateTime?
  actionTaken           ModerationAction @default(NONE)
  moderatorNotes        String?
  explanationToReporter String?
  explanationToReported String?
  createdAt             DateTime         @default(now())
  reporter              User?            @relation("Reporter", fields: [reporterId], references: [id], onDelete: SetNull)
  reportedUser          User?            @relation("ReportedUser", fields: [reportedUserId], references: [id], onDelete: SetNull)
  moderationLogs        ModerationLog[]

  @@index([status, createdAt])
  @@index([reportedUserId])
  @@index([reporterId])
  @@index([reportedThreadId])
  @@index([reportedReelId])
  @@index([reportedVideoId])
  @@map("reports")
}

model ModerationLog {
  id              String           @id @default(cuid())
  moderatorId     String?
  targetUserId    String?
  targetPostId    String?
  targetCommentId String?
  targetMessageId String?
  action          ModerationAction
  reason          String
  explanation     String
  reportId        String?
  isAppealed      Boolean          @default(false)
  appealText      String?
  appealResolved  Boolean?
  appealResult    String?
  createdAt       DateTime         @default(now())
  moderator       User?            @relation("Moderator", fields: [moderatorId], references: [id], onDelete: SetNull)
  targetUser      User?            @relation("ModTarget", fields: [targetUserId], references: [id], onDelete: SetNull)
  targetPost      Post?            @relation("ModPostTarget", fields: [targetPostId], references: [id], onDelete: SetNull)
  targetComment   Comment?         @relation("ModCommentTarget", fields: [targetCommentId], references: [id], onDelete: SetNull)
  targetMessage   Message?         @relation("ModMessageTarget", fields: [targetMessageId], references: [id], onDelete: SetNull)
  report          Report?          @relation(fields: [reportId], references: [id], onDelete: SetNull)

  @@index([targetUserId, createdAt(sort: Desc)])
  @@index([reportId])
  @@index([moderatorId])
  @@map("moderation_log")
}

// ============================================================
// BLOCKS & MUTES
// ============================================================

model Block {
  blockerId String
  blockedId String
  createdAt DateTime @default(now())
  blocker   User     @relation("Blocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked   User     @relation("Blocked", fields: [blockedId], references: [id], onDelete: Cascade)

  @@id([blockerId, blockedId])
  @@index([blockedId])
  @@map("blocks")
}

model Mute {
  userId    String
  mutedId   String
  createdAt DateTime @default(now())
  user      User     @relation("Muter", fields: [userId], references: [id], onDelete: Cascade)
  muted     User     @relation("Muted", fields: [mutedId], references: [id], onDelete: Cascade)

  @@id([userId, mutedId])
  @@index([mutedId])
  @@map("mutes")
}

// ============================================================
// HASHTAGS
// ============================================================

model Hashtag {
  id           String   @id @default(cuid())
  name         String   @unique
  postsCount   Int      @default(0)
  reelsCount   Int      @default(0)
  threadsCount Int      @default(0)
  videosCount  Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([name])
  @@index([postsCount(sort: Desc)])
  @@map("hashtags")
}

// ============================================================
// FEED ALGORITHM SIGNALS
// ============================================================

model FeedInteraction {
  id             String       @id @default(cuid())
  userId         String
  postId         String
  space          ContentSpace @default(SAF)
  viewed         Boolean      @default(false)
  viewDurationMs Int          @default(0)
  liked          Boolean      @default(false)
  commented      Boolean      @default(false)
  shared         Boolean      @default(false)
  saved          Boolean      @default(false)
  completionRate Float?
  createdAt      DateTime     @default(now())
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  post           Post         @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@index([userId, createdAt(sort: Desc)])
  @@index([postId])
  @@index([space, userId])
  @@map("feed_interactions")
}

// ============================================================
// WEEK 1 ADDITIONS
// ============================================================

model FollowRequest {
  id            String              @id @default(cuid())
  senderId      String
  receiverId    String
  status        FollowRequestStatus @default(PENDING)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  sender        User                @relation("SentFollowRequests", fields: [senderId], references: [id], onDelete: Cascade)
  receiver      User                @relation("ReceivedFollowRequests", fields: [receiverId], references: [id], onDelete: Cascade)
  notifications Notification[]

  @@unique([senderId, receiverId])
  @@index([receiverId, status])
  @@map("follow_requests")
}

model Poll {
  id            String       @id @default(cuid())
  threadId      String       @unique
  thread        Thread       @relation(fields: [threadId], references: [id], onDelete: Cascade)
  question      String       @db.VarChar(300)
  endsAt        DateTime?
  totalVotes    Int          @default(0)
  allowMultiple Boolean      @default(false)
  createdAt     DateTime     @default(now())
  options       PollOption[]

  @@map("polls")
}

model PollOption {
  id         String     @id @default(cuid())
  pollId     String
  poll       Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  text       String     @db.VarChar(100)
  votesCount Int        @default(0)
  position   Int        @default(0)
  createdAt  DateTime   @default(now())
  votes      PollVote[]

  @@index([pollId])
  @@map("poll_options")
}

model PollVote {
  userId    String
  optionId  String
  createdAt DateTime   @default(now())
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  option    PollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)

  @@id([userId, optionId])
  @@index([optionId])
  @@map("poll_votes")
}

model AudioTrack {
  id         String   @id @default(cuid())
  title      String   @db.VarChar(200)
  artist     String?  @db.VarChar(100)
  duration   Float
  audioUrl   String
  coverUrl   String?
  reelsCount Int      @default(0)
  isOriginal Boolean  @default(false)
  createdAt  DateTime @default(now())
  reels      Reel[]

  @@index([reelsCount(sort: Desc)])
  @@map("audio_tracks")
}

model ThreadBookmark {
  userId    String
  threadId  String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  thread    Thread   @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@id([userId, threadId])
  @@index([userId, createdAt(sort: Desc)])
  @@map("thread_bookmarks")
}

model VideoBookmark {
  userId    String
  videoId   String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  video     Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@id([userId, videoId])
  @@index([userId, createdAt(sort: Desc)])
  @@map("video_bookmarks")
}

model WatchHistory {
  id        String   @id @default(cuid())
  userId    String
  videoId   String
  watchedAt DateTime @default(now())
  progress  Float    @default(0)
  completed Boolean  @default(false)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  video     Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@unique([userId, videoId])
  @@index([userId, watchedAt(sort: Desc)])
  @@map("watch_history")
}

model WatchLater {
  userId    String
  videoId   String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  video     Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@id([userId, videoId])
  @@index([userId, createdAt(sort: Desc)])
  @@map("watch_later")
}

model MessageReaction {
  id        String   @id @default(cuid())
  messageId String
  userId    String
  emoji     String   @db.VarChar(10)
  createdAt DateTime @default(now())
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
  @@index([messageId])
  @@map("message_reactions")
}

model StoryHighlightAlbum {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String   @db.VarChar(50)
  coverUrl  String?
  position  Int      @default(0)
  createdAt DateTime @default(now())
  stories   Story[]

  @@index([userId])
  @@map("story_highlight_albums")
}

model StoryStickerResponse {
  id           String   @id @default(cuid())
  storyId      String
  userId       String
  stickerType  String
  responseData Json
  createdAt    DateTime @default(now())
  story        Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([storyId])
  @@map("story_sticker_responses")
}

model UserInterest {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category  String
  createdAt DateTime @default(now())

  @@unique([userId, category])
  @@index([userId])
  @@map("user_interests")
}

model FeedDismissal {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  contentId   String
  contentType String
  createdAt   DateTime @default(now())

  @@unique([userId, contentId, contentType])
  @@index([userId])
  @@map("feed_dismissals")
}

model DraftPost {
  id        String       @id @default(cuid())
  userId    String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  space     ContentSpace @default(SAF)
  data      Json
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@index([userId, updatedAt(sort: Desc)])
  @@map("draft_posts")
}

model ProfileLink {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String   @db.VarChar(50)
  url       String   @db.VarChar(500)
  position  Int      @default(0)
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("profile_links")
}

model Device {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  platform     String
  pushToken    String   @unique
  deviceId     String?
  deviceName   String?
  os           String?
  ipAddress    String?
  location     String?
  lastActiveAt DateTime @default(now())
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId])
  @@index([userId, lastActiveAt(sort: Desc)])
  @@map("devices")
}

model CallSession {
  id                String            @id @default(cuid())
  callType          CallType
  status            CallStatus        @default(RINGING)
  startedAt         DateTime?
  endedAt           DateTime?
  duration          Int?
  maxParticipants   Int               @default(2)
  isScreenSharing   Boolean           @default(false)
  screenShareUserId String?
  screenShareUser   User?             @relation("callScreenShare", fields: [screenShareUserId], references: [id], onDelete: SetNull)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  participants      CallParticipant[]

  @@index([status])
  @@index([createdAt])
  @@index([endedAt])
  @@map("call_sessions")
}

model CallParticipant {
  sessionId String
  userId    String
  role      String      @default("caller")
  joinedAt  DateTime    @default(now())
  leftAt    DateTime?
  session   CallSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([sessionId, userId])
  // @@index([sessionId]) — redundant: @@id already has sessionId as leading column
  @@index([userId])
  @@map("call_participants")
}

model StickerPack {
  id            String            @id @default(cuid())
  name          String            @db.VarChar(100)
  coverUrl      String?
  stickersCount Int               @default(0)
  isFree        Boolean           @default(true)
  ownerId       String?
  createdAt     DateTime          @default(now())
  stickers      Sticker[]
  users         UserStickerPack[]

  @@index([ownerId])
  @@map("sticker_packs")
}

model Sticker {
  id        String      @id @default(cuid())
  packId    String
  pack      StickerPack @relation(fields: [packId], references: [id], onDelete: Cascade)
  url       String
  name      String?     @db.VarChar(50)
  position  Int         @default(0)
  createdAt DateTime    @default(now())

  @@index([packId])
  @@map("stickers")
}

model UserStickerPack {
  userId  String
  packId  String
  addedAt DateTime    @default(now())
  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  pack    StickerPack @relation(fields: [packId], references: [id], onDelete: Cascade)

  @@id([userId, packId])
  // @@index([userId]) — redundant: @@id already has userId as leading column
  @@map("user_sticker_packs")
}

model GeneratedSticker {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation("generatedStickers", fields: [userId], references: [id], onDelete: Cascade)
  imageUrl  String
  prompt    String
  style     String   @default("cartoon")
  createdAt DateTime @default(now())

  @@index([userId, createdAt(sort: Desc)])
  @@map("generated_stickers")
}

model AltProfile {
  id          String             @id @default(cuid())
  userId      String             @unique
  user        User               @relation("altProfile", fields: [userId], references: [id], onDelete: Cascade)
  displayName String
  bio         String?            @db.VarChar(500)
  avatarUrl   String?
  isActive    Boolean            @default(true)
  createdAt   DateTime           @default(now())
  access      AltProfileAccess[]

  @@map("alt_profiles")
}

model AltProfileAccess {
  id           String     @id @default(cuid())
  altProfileId String
  altProfile   AltProfile @relation(fields: [altProfileId], references: [id], onDelete: Cascade)
  userId       String
  user         User       @relation("altProfileAccess", fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())

  @@unique([altProfileId, userId])
  @@index([userId])
  @@map("alt_profile_access")
}

model MajlisList {
  id           String             @id @default(cuid())
  ownerId      String
  owner        User               @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  name         String             @db.VarChar(100)
  description  String?            @db.VarChar(500)
  isPrivate    Boolean            @default(false)
  membersCount Int                @default(0)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  members      MajlisListMember[]

  @@index([ownerId])
  @@map("majlis_lists")
}

model MajlisListMember {
  listId  String
  userId  String
  addedAt DateTime   @default(now())
  list    MajlisList @relation(fields: [listId], references: [id], onDelete: Cascade)
  user    User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([listId, userId])
  @@index([userId])
