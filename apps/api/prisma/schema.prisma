  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  video Video @relation(fields: [videoId], references: [id], onDelete: Cascade)
  @@id([userId, videoId])
  @@index([userId, createdAt(sort: Desc)])
  @@map("video_bookmarks")
}

model WatchHistory {
  id        String   @id @default(cuid())
  userId    String
  videoId   String
