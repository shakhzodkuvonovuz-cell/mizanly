  updatedAt      DateTime @updatedAt

  @@map("encryption_keys")
}

model ConversationKeyEnvelope {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation("keyEnvelopes", fields: [conversationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation("conversationKeyEnvelopes", fields: [userId], references: [id], onDelete: Cascade)
  encryptedKey   String
  nonce          String
  version        Int          @default(1)
  createdAt      DateTime     @default(now())

  // Race condition prevention: this unique constraint prevents duplicate envelopes
  // for the same (conversation, user, version) tuple. First-message key exchange
  // races are caught by the version=1 duplicate; application should handle the
  // unique violation with a retry/upsert pattern rather than a bare create.
  @@unique([conversationId, userId, version])
  @@index([conversationId])
  @@index([userId])
  @@map("conversation_key_envelopes")
}

