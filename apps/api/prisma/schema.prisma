// ── Commerce Models (Tier 11) ───────────────────────────

model Product {
  id            String           @id @default(uuid())
  sellerId      String
  title         String           @db.VarChar(200)
  description   String           @db.VarChar(2000)
  price         Decimal          @db.Decimal(12, 2)
  currency      String           @default("USD")
  images        String[] // array of image URLs
  category      ProductCategory
  isHalal       Boolean          @default(true)
  halalCertUrl  String?
  isMuslimOwned Boolean          @default(false)
  stock         Int              @default(0)
  status        ProductStatus    @default(ACTIVE)
  rating        Decimal          @default(0) @db.Decimal(3, 2)
  reviewCount   Int              @default(0)
  salesCount    Int              @default(0)
  tags          String[]
  location      String?
  shippingInfo  String?          @db.VarChar(500)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  seller        User             @relation("ProductSeller", fields: [sellerId], references: [id], onDelete: Cascade)
  reviews       ProductReview[]
  orders        Order[]
  productTags   PostProductTag[]

  @@index([sellerId])
  @@index([category, status])
  @@map("products")
}

model ProductReview {
  id        String   @id @default(uuid())
  productId String
  userId    String
  rating    Int // 1-5
  comment   String?  @db.VarChar(500)
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([productId, userId])
  @@map("product_reviews")
}

model Order {
  id              String      @id @default(uuid())
  buyerId         String?
  productId       String
  quantity        Int         @default(1)
  totalAmount     Decimal     @db.Decimal(12, 2)
  currency        String      @default("USD")
  status          OrderStatus @default(PENDING)
  stripePaymentId String?
  installments    Int         @default(1) // 1 = full payment, 2-4 = split
  shippingAddress String?     @db.VarChar(500)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  buyer           User?       @relation("OrderBuyer", fields: [buyerId], references: [id], onDelete: SetNull)
  product         Product     @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([buyerId])
  @@index([buyerId, createdAt])
  @@index([productId])
  @@index([status])
  @@map("orders")
}

model PostProductTag {
  postId    String
  post      Post     @relation("productTags", fields: [postId], references: [id], onDelete: Cascade)
  productId String
  position  String? // x,y coordinates on image
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([postId, productId])
  @@map("post_product_tags")
}

