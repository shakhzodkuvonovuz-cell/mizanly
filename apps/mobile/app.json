{
  "expo": {
    "name": "Mizanly",
    "slug": "mizanly",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "mizanly",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A7B4F"
    },
    "assetBundlePatterns": [
      "assets/**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.mizanly.mobile",
      "associatedDomains": ["applinks:mizanly.com", "applinks:mizanly.app"],
      "infoPlist": {
        "NSCameraUsageDescription": "Mizanly needs camera access to create posts, stories, and reels",
        "NSMicrophoneUsageDescription": "Mizanly needs microphone access for voice notes and video recording",
        "NSPhotoLibraryUsageDescription": "Mizanly needs photo library access to share images and videos",
        "NSLocationWhenInUseUsageDescription": "Mizanly uses your location for prayer times, qibla direction, and finding nearby mosques.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0A7B4F"
      },
      "package": "app.mizanly.mobile",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            { "scheme": "https", "host": "mizanly.com", "pathPrefix": "/post" },
            { "scheme": "https", "host": "mizanly.com", "pathPrefix": "/reel" },
            { "scheme": "https", "host": "mizanly.com", "pathPrefix": "/profile" },
            { "scheme": "https", "host": "mizanly.com", "pathPrefix": "/thread" },
            { "scheme": "https", "host": "mizanly.app", "pathPrefix": "/post" },
            { "scheme": "https", "host": "mizanly.app", "pathPrefix": "/reel" },
            { "scheme": "https", "host": "mizanly.app", "pathPrefix": "/profile" },
            { "scheme": "https", "host": "mizanly.app", "pathPrefix": "/thread" }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ],
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.CAMERA",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION"
      ]
    },
    "jsEngine": "hermes",
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://mizanly.app"
        }
      ],
      "expo-image-picker",
      "expo-camera",
      [
        "expo-av",
        {
          "microphonePermission": "Allow Mizanly to access your microphone for voice notes and video."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#0A7B4F",
          "sounds": []
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Mizanly uses your location for prayer times, qibla direction, and finding nearby mosques."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash.png",
          "backgroundColor": "#0A7B4F",
          "resizeMode": "contain"
        }
      ],
      "expo-font",
      "expo-localization",
      "expo-secure-store",
      "expo-web-browser",
      "expo-screen-orientation",
      "expo-screen-capture",
      "./plugins/ffmpeg-kit/app.plugin",
      "./plugins/giphy-sdk/app.plugin",
      "./plugins/certificate-pinning/app.plugin",
      "react-native-quick-crypto"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "d5a4cde9-ecd1-4d17-bfb1-1d84fccd4b89"
      },
      "router": {
        "origin": "https://mizanly.app"
      }
    },
    "owner": "shaxzodbek"
  }
}
