# ── LiveKit (Voice/Video Calls) ──
EXPO_PUBLIC_LIVEKIT_URL=https://your-project.livekit.cloud
EXPO_PUBLIC_LIVEKIT_WS_URL=wss://your-project.livekit.cloud

# ── App Store ──
EXPO_PUBLIC_IOS_APP_STORE_URL=
