/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src https://fonts.gstatic.com; connect-src https://mizanlyapi-production.up.railway.app https://api.mizanly.app; img-src 'self' data:; frame-ancestors 'none'
  Strict-Transport-Security: max-age=31536000; includeSubDomains
