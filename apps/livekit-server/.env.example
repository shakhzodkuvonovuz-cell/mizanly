# ═══════════════════════════════════════════════════════════
# LiveKit Call Server — Environment Variables
# Copy to .env and fill in values
# ═══════════════════════════════════════════════════════════

# ── LiveKit Cloud ────────────────────────────────────────
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret
LIVEKIT_HOST=https://your-project.livekit.cloud

# ── Database (Neon PostgreSQL) ───────────────────────────
DATABASE_URL=postgres://user:pass@localhost:5432/mizanly_livekit?sslmode=disable

# ── Auth (Clerk — for JWT verification) ──────────────────
CLERK_SECRET_KEY=sk_test_...

# ── Cache & Rate Limiting (Redis) ────────────────────────
REDIS_URL=redis://localhost:6379

# ── Cloudflare R2 (call recording storage) ───────────────
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET=mizanly-media
R2_ENDPOINT=

# ── Inter-service (Go → NestJS push notifications) ──────
NESTJS_BASE_URL=http://localhost:3000/api/v1
INTERNAL_SERVICE_KEY=generate-a-random-secret-here

# ── Server ───────────────────────────────────────────────
PORT=8081

# ── Monitoring ───────────────────────────────────────────
SENTRY_DSN=
