# Required: Expo SDK 52 packages (expo-camera, expo-image, etc.) declare
# peer deps on react@18 / react-native@0.76, but we use react@19 / RN 0.81.
# Removing this flag causes ERESOLVE failures on 19+ packages.
# Re-check after upgrading to Expo SDK 53+ which targets React 19.
legacy-peer-deps=true
