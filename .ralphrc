# Ralph Configuration for Mizanly
PROJECT_NAME="mizanly"
PROJECT_TYPE="javascript"
MAX_ITERATIONS=200
RATE_LIMIT_PER_HOUR=100
SESSION_TIMEOUT=86400
CIRCUIT_BREAKER_THRESHOLD=5
TEST_ONLY_LOOP_LIMIT=3
AUTO_COMMIT=true
MONITOR_ENABLED=true

# Tool permissions
ALLOW_BASH=true
ALLOW_WRITE=true
ALLOW_READ=true
ALLOW_EDIT=true
ALLOW_GLOB=true
ALLOW_GREP=true
ALLOW_WEB_SEARCH=true
ALLOW_WEB_FETCH=true

# Protected paths
PROTECTED_PATHS=".ralph/,.ralphrc"
